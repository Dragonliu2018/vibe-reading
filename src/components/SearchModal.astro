---
/**
 * Pagefind 全文搜索模态框 — Apple 风格
 * 触发：⌘K / Ctrl+K 或 window.openSearch()
 */
---

<div class="srch-backdrop" id="srch-backdrop" aria-hidden="true"></div>

<div class="srch-dialog" id="srch-dialog" role="dialog" aria-modal="true" aria-label="搜索">

  <!-- 搜索输入行 -->
  <div class="srch-input-row">
    <svg class="srch-icon" width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true">
      <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.6"/>
      <path d="M11.5 11.5L15 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>
    <input
      id="srch-input"
      type="search"
      placeholder="搜索文章..."
      autocomplete="off"
      spellcheck="false"
    />
    <kbd class="srch-esc-key" id="srch-esc-key">ESC</kbd>
  </div>

  <!-- 结果列表 -->
  <div class="srch-results" id="srch-results" role="listbox"></div>

  <!-- 底部提示 -->
  <div class="srch-footer hidden" id="srch-footer">
    <span><kbd>↑↓</kbd>导航</span>
    <span><kbd>↵</kbd>打开</span>
    <span><kbd>esc</kbd>关闭</span>
    <span class="srch-brand">Pagefind</span>
  </div>

</div>

<style>
  /* ── 遮罩 ── */
  .srch-backdrop {
    display: none; position: fixed; inset: 0; z-index: 9000;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  }
  .srch-backdrop.open { display: block; }

  /* ── 对话框 ── */
  .srch-dialog {
    display: none;
    position: fixed;
    top: 14vh; left: 50%; transform: translateX(-50%);
    width: min(620px, 92vw);
    z-index: 9001;
    background: #111113;
    border: 1px solid rgba(255,255,255,0.13);
    border-radius: 18px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.5), 0 24px 64px rgba(0,0,0,0.65);
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', sans-serif;
  }
  .srch-dialog.open { display: flex; flex-direction: column; }

  /* ── 输入行 ── */
  .srch-input-row {
    display: flex; align-items: center; gap: 11px;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    flex-shrink: 0;
  }
  .srch-icon { color: #636366; flex-shrink: 0; }

  #srch-input {
    flex: 1; min-width: 0;
    background: none; border: none; outline: none;
    font-size: 17px; font-weight: 400;
    color: #f5f5f7; font-family: inherit;
    caret-color: #2997ff;
    letter-spacing: -0.2px;
    -webkit-appearance: none;
  }
  #srch-input::placeholder { color: #3a3a3c; }
  #srch-input::-webkit-search-cancel-button { display: none; }

  .srch-esc-key {
    flex-shrink: 0;
    font-size: 11px; color: #48484a;
    border: 1px solid rgba(255,255,255,0.10);
    padding: 3px 8px; border-radius: 6px;
    font-family: inherit; cursor: pointer;
    user-select: none;
  }

  /* ── 结果容器 ── */
  .srch-results {
    overflow-y: auto;
    max-height: min(440px, 48vh);
    padding: 6px 8px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.08) transparent;
  }
  .srch-results::-webkit-scrollbar { width: 4px; }
  .srch-results::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 2px; }

  /* ── 状态提示（空态 / 无结果） ── */
  .srch-state {
    padding: 44px 20px; text-align: center;
    color: #3a3a3c; font-size: 14px; line-height: 1.65;
  }
  .srch-state code {
    font-family: ui-monospace, 'SF Mono', monospace;
    font-size: 12.5px; color: #636366;
    background: rgba(255,255,255,0.06);
    padding: 1px 6px; border-radius: 4px;
  }

  /* ── 结果条目 ── */
  .srch-item {
    display: flex; align-items: center; gap: 13px;
    padding: 11px 12px;
    border-radius: 10px;
    text-decoration: none; color: inherit;
    cursor: pointer;
    transition: background .12s;
    outline: none;
    position: relative;
  }
  .srch-item + .srch-item { margin-top: 2px; }

  .srch-item:hover   { background: rgba(255,255,255,0.05); }
  .srch-item.active  {
    background: rgba(41,151,255,0.12);
  }
  .srch-item.active .srch-item-icon { color: #2997ff; }
  .srch-item.active .srch-item-title { color: #2997ff; }

  /* 左侧图标 */
  .srch-item-icon {
    flex-shrink: 0;
    width: 34px; height: 34px;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    display: flex; align-items: center; justify-content: center;
    color: #636366;
    transition: color .12s, background .12s;
  }
  .srch-item.active .srch-item-icon {
    background: rgba(41,151,255,0.15);
    border-color: rgba(41,151,255,0.25);
  }

  /* 中间文本 */
  .srch-item-body { flex: 1; min-width: 0; }

  .srch-item-title {
    font-size: 14px; font-weight: 600;
    color: #e8e8ed; letter-spacing: -0.3px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    margin-bottom: 3px;
    transition: color .12s;
  }

  .srch-item-excerpt {
    font-size: 12px; color: #636366; line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 匹配词高亮 */
  .srch-results mark {
    background: rgba(41,151,255,0.20);
    color: #79c0ff;
    border-radius: 2px;
    padding: 0 1px;
    font-style: normal;
  }

  .srch-item-path {
    font-size: 11px; color: #3a3a3c;
    margin-top: 4px; letter-spacing: 0.1px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  /* 右侧箭头 */
  .srch-item-arrow {
    flex-shrink: 0; color: #3a3a3c;
    transition: color .12s, transform .12s;
  }
  .srch-item.active .srch-item-arrow {
    color: #2997ff;
    transform: translateX(2px);
  }

  /* ── 底部提示栏 ── */
  .srch-footer {
    display: flex; align-items: center; gap: 12px;
    padding: 8px 20px;
    border-top: 1px solid rgba(255,255,255,0.06);
    font-size: 11px; color: #48484a;
    flex-shrink: 0;
  }
  .srch-footer kbd {
    border: 1px solid rgba(255,255,255,0.10);
    padding: 1px 5px; border-radius: 4px;
    font-family: inherit; font-size: 10.5px;
    margin-right: 2px;
  }
  .srch-brand { margin-left: auto; color: #2a2a2c; }
  .hidden { display: none !important; }

  /* ── 分组标签 ── */
  .srch-group {
    font-size: 10.5px; font-weight: 600; letter-spacing: 0.7px;
    text-transform: uppercase; color: #3a3a3c;
    padding: 10px 12px 3px;
    user-select: none;
  }
  .srch-group + .srch-group { padding-top: 6px; }
</style>

<script>
  const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

  const backdrop = document.getElementById('srch-backdrop')!;
  const dialog   = document.getElementById('srch-dialog')!;
  const input    = document.getElementById('srch-input') as HTMLInputElement;
  const results  = document.getElementById('srch-results')!;
  const footer   = document.getElementById('srch-footer')!;

  let pf: any   = null;
  let pfReady   = false;
  let activeIdx = -1;
  let debounce: ReturnType<typeof setTimeout>;

  /* ── Pagefind 懒加载 ─────────────────────────────────────────── */
  async function loadPf() {
    if (pfReady) return pf;
    try {
      pf = await import(/* @vite-ignore */ `${BASE}/pagefind/pagefind.js`);
      await pf.options({ baseUrl: `${BASE}/` });
      await pf.init();
      pfReady = true;
    } catch { pf = null; }
    return pf;
  }

  /* ── 打开 / 关闭 ─────────────────────────────────────────────── */
  function openSearch() {
    backdrop.classList.add('open');
    dialog.classList.add('open');
    footer.classList.add('hidden');
    results.innerHTML = hint('输入关键词搜索文章…');
    requestAnimationFrame(() => input.focus());
    loadPf();
  }
  function closeSearch() {
    backdrop.classList.remove('open');
    dialog.classList.remove('open');
    input.value = '';
    results.innerHTML = '';
    activeIdx = -1;
  }
  (window as any).openSearch = openSearch;

  backdrop.addEventListener('click', closeSearch);
  document.getElementById('srch-esc-key')?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); dialog.classList.contains('open') ? closeSearch() : openSearch(); }
    if (e.key === 'Escape' && dialog.classList.contains('open')) closeSearch();
  });

  /* ── 搜索 ────────────────────────────────────────────────────── */
  input.addEventListener('input', () => {
    clearTimeout(debounce);
    debounce = setTimeout(doSearch, 200);
  });

  async function doSearch() {
    const q = input.value.trim();
    if (!q) { results.innerHTML = hint('输入关键词搜索文章…'); footer.classList.add('hidden'); return; }

    const engine = await loadPf();
    if (!engine) {
      results.innerHTML = hint('搜索索引尚未生成，请先执行 <code>npm run build</code>');
      footer.classList.add('hidden');
      return;
    }

    const search = await engine.search(q);
    if (!search.results.length) {
      results.innerHTML = hint(`没有找到与「${q}」相关的文章`);
      footer.classList.add('hidden');
      activeIdx = -1;
      return;
    }

    /* ① 加载最多 20 条原始结果 */
    const raw: any[] = await Promise.all(
      search.results.slice(0, 20).map((r: any) => r.data())
    );

    /* ② 按 URL 去重（去锚点），保留 pagefind 排在最前的摘录 */
    const seen = new Map<string, any>();
    for (const item of raw) {
      const key = item.url.replace(/#.*$/, '');
      if (!seen.has(key)) seen.set(key, item);
    }
    const deduped = [...seen.values()].slice(0, 10);

    /* ③ 按优先级分组：标题命中 > 正文命中 */
    const ql = q.toLowerCase();
    const titleHits: any[] = [];
    const bodyHits:  any[] = [];
    for (const item of deduped) {
      const title = (item.meta?.title ?? '').toLowerCase();
      (title.includes(ql) ? titleHits : bodyHits).push(item);
    }

    /* ④ 渲染：标题匹配组在前，正文匹配组在后，组间有标签 */
    const hasBoth = titleHits.length > 0 && bodyHits.length > 0;
    let idx = 0;
    let html = '';

    if (titleHits.length) {
      if (hasBoth) html += `<div class="srch-group">标题匹配</div>`;
      html += titleHits.map(item => renderItem(item, idx++)).join('');
    }
    if (bodyHits.length) {
      // 只展示到总数 8 篇
      const remaining = 8 - titleHits.length;
      if (hasBoth) html += `<div class="srch-group">正文匹配</div>`;
      html += bodyHits.slice(0, remaining).map(item => renderItem(item, idx++)).join('');
    }

    activeIdx = -1;
    footer.classList.remove('hidden');
    results.innerHTML = html;
  }

  /* ── 渲染单条结果 ────────────────────────────────────────────── */
  function renderItem(item: any, i: number): string {
    const title   = item.meta?.title ?? '无标题';
    const excerpt = item.excerpt ?? '';
    // 路径展示：去掉 base 前缀，截取 /articles/xxx
    const path    = item.url.replace(BASE, '').replace(/\/$/, '') || '/';

    return `<a class="srch-item" href="${item.url}" data-idx="${i}" role="option" tabindex="-1">
      <div class="srch-item-icon" aria-hidden="true">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
          <rect x="2" y="1" width="9" height="11" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
          <path d="M4 5h5M4 7.5h5M4 10h3" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="srch-item-body">
        <div class="srch-item-title">${title}</div>
        <div class="srch-item-excerpt">${excerpt}</div>
        <div class="srch-item-path">${path}</div>
      </div>
      <svg class="srch-item-arrow" width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
        <path d="M2.5 6.5h8M7 3l3.5 3.5L7 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>`;
  }

  /* ── 键盘导航 ────────────────────────────────────────────────── */
  input.addEventListener('keydown', (e: KeyboardEvent) => {
    const items = results.querySelectorAll<HTMLElement>('.srch-item');
    if (!items.length) return;
    if (e.key === 'ArrowDown') { e.preventDefault(); activeIdx = Math.min(activeIdx + 1, items.length - 1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); activeIdx = Math.max(activeIdx - 1, 0); }
    else if (e.key === 'Enter')  { e.preventDefault(); (activeIdx >= 0 ? items[activeIdx] : items[0])?.click(); return; }
    else return;
    items.forEach((el, i) => el.classList.toggle('active', i === activeIdx));
    items[activeIdx]?.scrollIntoView({ block: 'nearest' });
  });

  /* ── 工具函数 ────────────────────────────────────────────────── */
  function hint(msg: string) {
    return `<div class="srch-state">${msg}</div>`;
  }
</script>
