---
/**
 * Pagefind 全文搜索 — 极简文字层级风格
 * 参考 VitePress / Algolia DocSearch 的结果展示方式
 */
---

<div class="srch-overlay" id="srch-backdrop" aria-hidden="true"></div>

<div class="srch-box" id="srch-dialog" role="dialog" aria-modal="true" aria-label="搜索">

  <div class="srch-head">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="srch-head-icon">
      <circle cx="6.5" cy="6.5" r="4.75" stroke="currentColor" stroke-width="1.5"/>
      <path d="M10.75 10.75L14.25 14.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <input
      id="srch-input"
      type="search"
      placeholder="搜索文章..."
      autocomplete="off"
      spellcheck="false"
      aria-label="搜索"
    />
    <button class="srch-esc" id="srch-esc" aria-label="关闭搜索">ESC</button>
  </div>

  <div class="srch-body" id="srch-results" role="listbox">
    <p class="srch-placeholder">输入关键词搜索文章…</p>
  </div>

  <div class="srch-foot hidden" id="srch-footer">
    <span class="srch-hint"><kbd>↑</kbd><kbd>↓</kbd> 导航</span>
    <span class="srch-hint"><kbd>↵</kbd> 打开</span>
    <span class="srch-hint"><kbd>esc</kbd> 关闭</span>
    <span class="srch-powered">Pagefind</span>
  </div>

</div>

<style>
  /* ── 遮罩 ──────────────────────────────────────────────────── */
  .srch-overlay {
    display: none;
    position: fixed; inset: 0; z-index: 9000;
    background: rgba(0,0,0,0.50);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .srch-overlay.open { display: block; }

  /* ── 对话框 ─────────────────────────────────────────────────── */
  .srch-box {
    display: none;
    position: fixed;
    top: 13vh; left: 50%; transform: translateX(-50%);
    width: min(660px, 94vw);
    z-index: 9001;
    background: #0f0f11;
    border: 1px solid rgba(255,255,255,0.11);
    border-radius: 14px;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.04),
      0 8px 24px rgba(0,0,0,0.45),
      0 32px 80px rgba(0,0,0,0.55);
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', sans-serif;
    overflow: hidden;
    flex-direction: column;
  }
  .srch-box.open { display: flex; }

  /* ── 输入行 ─────────────────────────────────────────────────── */
  .srch-head {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 18px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    flex-shrink: 0;
  }
  .srch-head-icon { color: #48484a; flex-shrink: 0; }

  #srch-input {
    flex: 1; min-width: 0;
    background: none; border: none; outline: none;
    font-size: 16px; color: #f2f2f7;
    font-family: inherit; letter-spacing: -0.15px;
    caret-color: #2997ff;
    -webkit-appearance: none;
  }
  #srch-input::placeholder { color: #38383a; }
  #srch-input::-webkit-search-cancel-button { display: none; }

  .srch-esc {
    flex-shrink: 0;
    padding: 3px 8px; border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.09);
    background: none; cursor: pointer;
    font-size: 11px; color: #48484a;
    font-family: inherit; letter-spacing: 0.2px;
    transition: border-color .15s, color .15s;
  }
  .srch-esc:hover { border-color: rgba(255,255,255,0.2); color: #86868b; }

  /* ── 结果区 ─────────────────────────────────────────────────── */
  .srch-body {
    overflow-y: auto;
    max-height: min(460px, 50vh);
    padding: 8px 10px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.07) transparent;
  }
  .srch-body::-webkit-scrollbar { width: 3px; }
  .srch-body::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.07); border-radius: 2px; }

  /* 空态 / 提示 */
  .srch-placeholder, .srch-empty {
    padding: 40px 10px; text-align: center;
    font-size: 14px; color: #38383a; line-height: 1.7;
  }
  .srch-empty code {
    font-family: ui-monospace, 'SF Mono', monospace;
    font-size: 12px; color: #48484a;
    background: rgba(255,255,255,0.05);
    padding: 1px 6px; border-radius: 4px;
  }

  /* ── 每个搜索结果条目 ────────────────────────────────────────── */
  .srch-hit {
    display: block;
    padding: 11px 14px;
    border-radius: 8px;
    text-decoration: none; color: inherit;
    cursor: pointer; outline: none;
    border-left: 2px solid transparent;
    transition: background .12s, border-color .12s;
  }
  .srch-hit + .srch-hit { margin-top: 1px; }

  .srch-hit:hover {
    background: rgba(255,255,255,0.04);
  }
  /* 键盘 active 状态：蓝色左边框 + 极淡蓝底 */
  .srch-hit.active {
    background: rgba(41,151,255,0.08);
    border-left-color: #2997ff;
  }

  /* 标题 */
  .srch-hit-title {
    font-size: 14.5px; font-weight: 600;
    color: #e5e5ea; letter-spacing: -0.3px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    margin-bottom: 5px;
    transition: color .12s;
  }
  .srch-hit.active .srch-hit-title { color: #2997ff; }

  /* 摘录 */
  .srch-hit-excerpt {
    font-size: 12.5px; color: #636366; line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 6px;
  }

  /* 高亮匹配词 */
  .srch-body mark {
    background: none;
    color: #79c0ff;
    font-weight: 600;
  }

  /* 路径面包屑 */
  .srch-hit-path {
    font-size: 11px; color: #3a3a3c;
    letter-spacing: 0.1px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .srch-hit-path span { opacity: 0.6; margin: 0 3px; }   /* › 分隔符 */

  /* ── 底部提示 ───────────────────────────────────────────────── */
  .srch-foot {
    display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
    padding: 8px 18px;
    border-top: 1px solid rgba(255,255,255,0.06);
    flex-shrink: 0;
  }
  .srch-hint {
    display: flex; align-items: center; gap: 3px;
    font-size: 11px; color: #48484a;
  }
  .srch-hint kbd {
    display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 4px; padding: 1px 5px;
    font-size: 10.5px; font-family: inherit;
    min-width: 18px;
    color: #3a3a3c;
  }
  .srch-powered { margin-left: auto; font-size: 11px; color: #28282a; }
  .hidden { display: none !important; }
</style>

<script>
  const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

  const overlay  = document.getElementById('srch-backdrop')!;
  const box      = document.getElementById('srch-dialog')!;
  const input    = document.getElementById('srch-input') as HTMLInputElement;
  const body     = document.getElementById('srch-results')!;
  const foot     = document.getElementById('srch-footer')!;
  const escBtn   = document.getElementById('srch-esc')!;

  let pf: any   = null;
  let pfReady   = false;
  let activeIdx = -1;
  let debounce: ReturnType<typeof setTimeout>;

  /* ── Pagefind 懒加载 ──────────────────────────────────────── */
  async function loadPf() {
    if (pfReady) return pf;
    try {
      pf = await import(/* @vite-ignore */ `${BASE}/pagefind/pagefind.js`);
      await pf.options({ baseUrl: `${BASE}/` });
      await pf.init();
      pfReady = true;
    } catch { pf = null; }
    return pf;
  }

  /* ── 打开 / 关闭 ─────────────────────────────────────────── */
  function open() {
    overlay.classList.add('open');
    box.classList.add('open');
    foot.classList.add('hidden');
    body.innerHTML = '<p class="srch-placeholder">输入关键词搜索文章…</p>';
    requestAnimationFrame(() => input.focus());
    loadPf();
  }
  function close() {
    overlay.classList.remove('open');
    box.classList.remove('open');
    input.value = '';
    body.innerHTML = '';
    activeIdx = -1;
  }
  (window as any).openSearch = open;

  overlay.addEventListener('click', close);
  escBtn.addEventListener('click', close);
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); box.classList.contains('open') ? close() : open(); }
    if (e.key === 'Escape' && box.classList.contains('open')) close();
  });

  /* ── 搜索 ──────────────────────────────────────────────────── */
  input.addEventListener('input', () => {
    clearTimeout(debounce);
    debounce = setTimeout(search, 200);
  });

  async function search() {
    const q = input.value.trim();
    if (!q) {
      body.innerHTML = '<p class="srch-placeholder">输入关键词搜索文章…</p>';
      foot.classList.add('hidden');
      return;
    }

    const engine = await loadPf();
    if (!engine) {
      body.innerHTML = '<p class="srch-empty">请先执行 <code>npm run build</code> 生成搜索索引</p>';
      foot.classList.add('hidden');
      return;
    }

    const res = await engine.search(q);
    if (!res.results.length) {
      body.innerHTML = `<p class="srch-empty">未找到「${q}」相关文章</p>`;
      foot.classList.add('hidden');
      activeIdx = -1;
      return;
    }

    /* 加载 24 条原始结果，按 URL 去重，每篇文章保留相关度最高的摘录 */
    const raw: any[] = await Promise.all(res.results.slice(0, 24).map((r: any) => r.data()));
    const seen = new Map<string, any>();
    for (const item of raw) {
      const url = item.url.replace(/#.*$/, '');
      if (!seen.has(url)) seen.set(url, item);
    }
    const deduped = [...seen.values()];

    /* 标题命中的排在前面，正文命中的排后面，各自保持 pagefind 原始顺序 */
    const ql = q.toLowerCase();
    const titleHits = deduped.filter(i => (i.meta?.title ?? '').toLowerCase().includes(ql));
    const bodyHits  = deduped.filter(i => !(i.meta?.title ?? '').toLowerCase().includes(ql));
    const ordered   = [...titleHits, ...bodyHits].slice(0, 8);

    activeIdx = -1;
    foot.classList.remove('hidden');
    body.innerHTML = ordered.map((item, i) => render(item, i)).join('');
  }

  /* ── 渲染单条结果 ─────────────────────────────────────────── */
  function render(item: any, i: number): string {
    const title   = escHtml(item.meta?.title ?? '未知文章');
    const excerpt = item.excerpt ?? '';   // pagefind 已处理 <mark>

    /* 面包屑：/articles/mycli-architecture → articles › mycli-architecture */
    const raw  = item.url.replace(BASE, '').replace(/^\/|\/$/g, '');
    const crumbs = raw.split('/').filter(Boolean);
    const pathHtml = crumbs
      .map((c, j) => j < crumbs.length - 1
        ? `${escHtml(c)}<span aria-hidden="true"> › </span>`
        : `<strong>${escHtml(c)}</strong>`)
      .join('');

    return `<a class="srch-hit" href="${item.url}" data-idx="${i}" role="option" tabindex="-1">
      <div class="srch-hit-title">${title}</div>
      <div class="srch-hit-excerpt">${excerpt}</div>
      <div class="srch-hit-path">${pathHtml}</div>
    </a>`;
  }

  function escHtml(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  /* ── 键盘导航 ─────────────────────────────────────────────── */
  input.addEventListener('keydown', (e: KeyboardEvent) => {
    const hits = body.querySelectorAll<HTMLElement>('.srch-hit');
    if (!hits.length) return;
    if      (e.key === 'ArrowDown') { e.preventDefault(); activeIdx = Math.min(activeIdx + 1, hits.length - 1); }
    else if (e.key === 'ArrowUp')   { e.preventDefault(); activeIdx = Math.max(activeIdx - 1, 0); }
    else if (e.key === 'Enter')     { e.preventDefault(); (activeIdx >= 0 ? hits[activeIdx] : hits[0])?.click(); return; }
    else return;
    hits.forEach((el, i) => el.classList.toggle('active', i === activeIdx));
    hits[activeIdx]?.scrollIntoView({ block: 'nearest' });
  });
</script>
