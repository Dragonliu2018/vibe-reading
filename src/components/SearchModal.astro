---
/**
 * Pagefind 全文搜索模态框
 * 触发：⌘K / Ctrl+K 或 window.openSearch()
 * 依赖：build 后 dist/pagefind/ 中的 pagefind.js
 */
---

<!-- Backdrop -->
<div class="srch-backdrop" id="srch-backdrop" aria-hidden="true"></div>

<!-- Dialog -->
<div class="srch-dialog" id="srch-dialog" role="dialog" aria-modal="true" aria-label="搜索">

  <!-- Input row -->
  <div class="srch-input-row">
    <svg class="srch-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5"/>
      <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <input
      id="srch-input"
      type="search"
      placeholder="搜索文章..."
      autocomplete="off"
      spellcheck="false"
    />
    <kbd class="srch-esc-key">ESC</kbd>
  </div>

  <!-- Results -->
  <div class="srch-results" id="srch-results" role="listbox"></div>

  <!-- Footer hints -->
  <div class="srch-footer" id="srch-footer">
    <span><kbd>↑↓</kbd> 导航</span>
    <span><kbd>↵</kbd> 打开</span>
    <span><kbd>esc</kbd> 关闭</span>
    <span class="srch-footer-brand">Powered by Pagefind</span>
  </div>

</div>

<style>
  /* ── Backdrop ── */
  .srch-backdrop {
    display: none;
    position: fixed; inset: 0; z-index: 9000;
    background: rgba(0,0,0,0.60);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .srch-backdrop.open { display: block; }

  /* ── Dialog ── */
  .srch-dialog {
    display: none;
    position: fixed;
    top: 16vh; left: 50%; transform: translateX(-50%);
    width: min(640px, 92vw);
    z-index: 9001;
    background: #141416;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 16px;
    box-shadow:
      0 2px 8px rgba(0,0,0,0.40),
      0 16px 48px rgba(0,0,0,0.60);
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', sans-serif;
  }
  .srch-dialog.open { display: flex; flex-direction: column; }

  /* ── Input row ── */
  .srch-input-row {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 18px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    flex-shrink: 0;
  }

  .srch-icon { color: #636366; flex-shrink: 0; }

  #srch-input {
    flex: 1; min-width: 0;
    background: none; border: none; outline: none;
    font-size: 16px; color: #f5f5f7;
    font-family: inherit;
    caret-color: #2997ff;
    /* remove browser search cancel button */
    -webkit-appearance: none;
  }
  #srch-input::placeholder { color: #48484a; }
  #srch-input::-webkit-search-cancel-button { display: none; }

  .srch-esc-key {
    font-size: 11px; color: #636366;
    border: 1px solid rgba(255,255,255,0.12);
    padding: 2px 7px; border-radius: 5px;
    font-family: inherit; flex-shrink: 0;
    cursor: pointer;
  }

  /* ── Results ── */
  .srch-results {
    overflow-y: auto;
    max-height: min(420px, 45vh);
    flex: 1;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.1) transparent;
  }
  .srch-results::-webkit-scrollbar { width: 4px; }
  .srch-results::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

  .srch-result {
    display: block;
    padding: 13px 18px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    text-decoration: none; color: inherit;
    cursor: pointer;
    transition: background .1s;
    outline: none;
  }
  .srch-result:last-child { border-bottom: none; }
  .srch-result:hover,
  .srch-result.active {
    background: rgba(41,151,255,0.10);
  }

  .srch-result-title {
    font-size: 14.5px; font-weight: 600;
    color: #f5f5f7; margin-bottom: 4px;
    letter-spacing: -0.3px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .srch-result-excerpt {
    font-size: 12.5px; color: #86868b; line-height: 1.55;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Highlight matched text */
  .srch-result-excerpt :global(mark),
  .srch-results mark {
    background: rgba(41,151,255,0.22);
    color: #79c0ff;
    border-radius: 2px;
    padding: 0 1px;
  }

  .srch-empty {
    padding: 48px 20px; text-align: center;
    color: #48484a; font-size: 14px;
  }

  .srch-hint {
    padding: 48px 20px; text-align: center;
    color: #48484a; font-size: 13px; line-height: 1.6;
  }

  /* ── Footer ── */
  .srch-footer {
    display: flex; align-items: center; gap: 14px;
    padding: 9px 18px;
    border-top: 1px solid rgba(255,255,255,0.06);
    font-size: 11.5px; color: #636366;
    flex-shrink: 0;
  }
  .srch-footer kbd {
    border: 1px solid rgba(255,255,255,0.12);
    padding: 1px 5px; border-radius: 4px;
    font-family: inherit; font-size: 10.5px;
    margin-right: 3px;
  }
  .srch-footer-brand { margin-left: auto; color: #3a3a3c; }

  /* ── No footer when empty ── */
  .srch-footer.hidden { display: none; }
</style>

<script>
  const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

  const backdrop = document.getElementById('srch-backdrop')!;
  const dialog   = document.getElementById('srch-dialog')!;
  const input    = document.getElementById('srch-input') as HTMLInputElement;
  const results  = document.getElementById('srch-results')!;
  const footer   = document.getElementById('srch-footer')!;

  let pf: any       = null;
  let pfReady       = false;
  let activeIdx     = -1;
  let debounceTimer: ReturnType<typeof setTimeout>;

  // ── Load Pagefind lazily ─────────────────────────────────────────
  async function loadPf() {
    if (pfReady) return pf;
    try {
      pf = await import(/* @vite-ignore */ `${BASE}/pagefind/pagefind.js`);
      await pf.options({ baseUrl: `${BASE}/` });
      await pf.init();
      pfReady = true;
    } catch {
      pfReady = false;
      pf = null;
    }
    return pf;
  }

  // ── Open / Close ─────────────────────────────────────────────────
  function openSearch() {
    backdrop.classList.add('open');
    dialog.classList.add('open');
    footer.classList.add('hidden');
    results.innerHTML = `<div class="srch-hint">输入关键词搜索文章…</div>`;
    requestAnimationFrame(() => input.focus());
    loadPf(); // preload
  }

  function closeSearch() {
    backdrop.classList.remove('open');
    dialog.classList.remove('open');
    input.value = '';
    results.innerHTML = '';
    activeIdx = -1;
  }

  // Expose globally so nav buttons can call it
  (window as any).openSearch = openSearch;

  // ── Keyboard shortcuts ───────────────────────────────────────────
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      dialog.classList.contains('open') ? closeSearch() : openSearch();
    }
    if (e.key === 'Escape' && dialog.classList.contains('open')) {
      closeSearch();
    }
  });

  backdrop.addEventListener('click', closeSearch);
  document.getElementById('srch-esc-key' as any)?.addEventListener('click', closeSearch);

  // ── Search ───────────────────────────────────────────────────────
  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(doSearch, 180);
  });

  async function doSearch() {
    const q = input.value.trim();

    if (!q) {
      results.innerHTML = `<div class="srch-hint">输入关键词搜索文章…</div>`;
      footer.classList.add('hidden');
      activeIdx = -1;
      return;
    }

    const engine = await loadPf();
    if (!engine) {
      results.innerHTML = `<div class="srch-empty">搜索功能需要先执行 <code>npm run build</code></div>`;
      footer.classList.add('hidden');
      return;
    }

    const search = await engine.search(q);

    if (!search.results.length) {
      results.innerHTML = `<div class="srch-empty">没有找到与「${q}」相关的文章</div>`;
      footer.classList.add('hidden');
      activeIdx = -1;
      return;
    }

    // Load top 8 results
    const items = await Promise.all(
      search.results.slice(0, 8).map((r: any) => r.data())
    );

    activeIdx = -1;
    footer.classList.remove('hidden');

    results.innerHTML = items.map((item: any, i: number) => `
      <a
        class="srch-result"
        href="${item.url}"
        data-idx="${i}"
        role="option"
        tabindex="-1"
      >
        <div class="srch-result-title">${item.meta?.title ?? item.url}</div>
        <div class="srch-result-excerpt">${item.excerpt}</div>
      </a>
    `).join('');
  }

  // ── Keyboard navigation in results ───────────────────────────────
  input.addEventListener('keydown', (e: KeyboardEvent) => {
    const items = results.querySelectorAll<HTMLElement>('.srch-result');
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIdx = Math.min(activeIdx + 1, items.length - 1);
      updateActive(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIdx = Math.max(activeIdx - 1, 0);
      updateActive(items);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      const target = activeIdx >= 0 ? items[activeIdx] : items[0];
      (target as HTMLAnchorElement)?.click();
    }
  });

  function updateActive(items: NodeListOf<HTMLElement>) {
    items.forEach((el, i) => el.classList.toggle('active', i === activeIdx));
    items[activeIdx]?.scrollIntoView({ block: 'nearest' });
  }
</script>
