---
import type { TreeNode } from '../data/categories';
import type { ToolNode } from '../data/tools-tree';
import { articles } from '../data/articles';
import { categoryTree, findActivePath } from '../data/categories';
import { toolsTree } from '../data/tools-tree';

export interface Props {
  currentSlug?: string;               // 文章模式：当前文章 slug
  mode?:        'articles' | 'tools'; // 默认 articles
  currentHref?: string;               // 工具模式：当前工具路径（如 /tools/diff）
}

const { currentSlug, mode = 'articles', currentHref } = Astro.props;
const base        = import.meta.env.BASE_URL.replace(/\/$/, '');
const activePath  = findActivePath(categoryTree, currentSlug);

/** HTML 转义 */
function esc(s: string): string {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

const chevron = `<svg class="tree-chevron" viewBox="0 0 12 12" fill="none" aria-hidden="true">
  <path d="M4.5 3L7.5 6L4.5 9" stroke="currentColor" stroke-width="1.3"
        stroke-linecap="round" stroke-linejoin="round"/>
</svg>`;

// ── 文章模式：递归渲染分类树 ──────────────────────────────────────
function renderNode(node: TreeNode, depth: number = 0): string {
  const isOpen   = activePath.has(node.key);
  const catClass = `tree-cat${depth > 0 ? ' tree-cat-sub' : ''}${isOpen ? ' open' : ''}`;
  const divClass = `tree-children${isOpen ? ' open' : ''}`;

  const childHtml   = (node.children ?? []).map(c => renderNode(c, depth + 1)).join('');
  const articleHtml = (node.slugs ?? []).map(slug => {
    const article = articles.find(a => a.slug === slug);
    const { source } = article ?? {};
    const baseTitle    = article?.title ?? slug;
    const displayTitle = source
      ? `[${source.project} ${source.type}-${source.id}] ${baseTitle}`
      : baseTitle;
    const active = slug === currentSlug ? ' active' : '';
    return `<a class="tree-article${active}" href="${base}/articles/${slug}" title="${esc(displayTitle)}">${esc(displayTitle)}</a>`;
  }).join('');

  return `<div class="tree-node">
  <button class="${catClass}" data-key="${esc(node.key)}">
    ${chevron}<span class="tree-cat-name">${esc(node.label)}</span>
  </button>
  <div class="${divClass}">${childHtml}${articleHtml}</div>
</div>`;
}

// ── 工具模式：渲染工具树 ──────────────────────────────────────────
function renderToolNode(node: ToolNode, depth: number = 0): string {
  // 叶节点：直接链接到工具页
  if (node.href) {
    const fullHref = `${base}${node.href}`;
    const active   = currentHref === node.href ? ' active' : '';
    return `<a class="tree-article${active}" href="${fullHref}">${esc(node.label)}</a>`;
  }

  // 中间节点：可折叠分组（工具较少，默认展开）
  const catClass = `tree-cat${depth > 0 ? ' tree-cat-sub' : ''} open`;
  const childHtml = (node.children ?? []).map(c => renderToolNode(c, depth + 1)).join('');

  return `<div class="tree-node">
  <button class="${catClass}" data-key="${esc(node.key)}">
    ${chevron}<span class="tree-cat-name">${esc(node.label)}</span>
  </button>
  <div class="tree-children open">${childHtml}</div>
</div>`;
}

const treeHtml     = categoryTree.map(n => renderNode(n)).join('');
const toolTreeHtml = toolsTree.map(n => renderToolNode(n)).join('');
---

<!-- Sidebar：文章/工具双模式 -->
<aside class="sidebar" id="g-sidebar" data-pagefind-ignore="all">

  <!-- 移动端模式切换（桌面端在 nav 里，移动端在侧边栏顶部）-->
  <div class="mob-mode-toggle">
    <a href={`${base}/`}
       class:list={['mob-mode-btn', { active: mode !== 'tools' }]}>
      Articles
    </a>
    <a href={`${base}/tools`}
       class:list={['mob-mode-btn', { active: mode === 'tools' }]}>
      Tools
    </a>
  </div>

  {mode === 'tools' ? (
    <>
      <p class="tree-label">Tools</p>
      <Fragment set:html={toolTreeHtml} />
    </>
  ) : (
    <>
      <p class="tree-label">Categories</p>
      <Fragment set:html={treeHtml} />
    </>
  )}
</aside>

<!-- 同步还原分类展开状态（is:inline = 不 defer，首次绘制前执行，消除闪动）-->
<script is:inline>
  (function () {
    try {
      var sidebar = document.getElementById('g-sidebar');
      if (!sidebar) return;
      var keys = JSON.parse(localStorage.getItem('sidebar-open-cats') || '[]');
      keys.forEach(function (key) {
        var btn = sidebar.querySelector('[data-key="' + key + '"]');
        if (btn && !btn.classList.contains('open')) {
          btn.classList.add('open');
          var list = btn.nextElementSibling;
          if (list) list.classList.add('open');
        }
      });
    } catch (_) {}
  })();
</script>

<!-- Mobile backdrop (click to close) -->
<div class="mob-backdrop" id="g-mob-backdrop" aria-hidden="true"></div>

<!-- Draggable divider + collapse toggle -->
<div class="resize-handle" id="g-resize-handle">
  <button class="sidebar-toggle" id="g-sidebar-toggle"
          title="折叠侧边栏" aria-label="折叠侧边栏">
    <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
      <path d="M6.5 2L3.5 5L6.5 8" stroke="currentColor" stroke-width="1.4"
            stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</div>

<style is:global>
  /* ── Sidebar — Mobile: slide-in overlay ── */
  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: min(300px, 82vw);
    height: 100%;
    z-index: 6000;
    background: #09090e;
    border-right: 1px solid rgba(255,255,255,0.08);
    overflow-y: auto;
    padding: 24px 12px 40px 20px;
    scrollbar-width: none;
    transform: translateX(-100%);
    transition: transform .28s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  .sidebar::-webkit-scrollbar { display: none; }
  .sidebar.mob-open { transform: translateX(0); }

  .mob-backdrop {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px);
    z-index: 5999;
    opacity: 0; transition: opacity .25s ease;
  }
  .mob-backdrop.mob-open { display: block; opacity: 1; }

  /* ── Sidebar — Desktop: inline panel ── */
  @media (min-width: 960px) {
    .sidebar {
      position: relative;
      transform: none;
      flex-shrink: 0;
      width: 240px; min-width: 120px; max-width: 480px;
      height: 100%;
      padding: 40px 12px 40px 20px;
      background: transparent; border-right: none; z-index: auto;
      transition:
        width .28s cubic-bezier(0.4, 0, 0.2, 1),
        padding .28s cubic-bezier(0.4, 0, 0.2, 1),
        min-width .28s;
    }
    .sidebar.collapsed {
      width: 0 !important; min-width: 0;
      padding-left: 0; padding-right: 0; overflow: hidden;
    }
    .mob-backdrop { display: none !important; }
  }

  /* ── Resize handle ── */
  .resize-handle { display: none; }

  @media (min-width: 960px) {
    .resize-handle {
      display: block; flex-shrink: 0; width: 12px;
      cursor: col-resize; position: relative;
      overflow: visible; background: transparent;
    }
    .resize-handle::before {
      content: ''; position: absolute; left: 5px; top: 0; bottom: 0;
      width: 1px; background: rgba(255,255,255,0.14); transition: background .18s;
    }
    .resize-handle::after {
      content: ''; position: absolute; left: 50%; top: 50%;
      transform: translate(-50%, -50%);
      width: 4px; height: 48px; border-radius: 2px;
      background: rgba(255,255,255,0); transition: background .18s, box-shadow .18s;
    }
    .resize-handle:hover::before  { background: rgba(255,255,255,0.28); }
    .resize-handle:hover::after   { background: rgba(255,255,255,0.20); }
    .resize-handle.dragging::before {
      background: rgba(41,151,255,0.7);
    }
    .resize-handle.dragging::after {
      background: rgba(41,151,255,0.45);
      box-shadow: 0 0 10px rgba(41,151,255,0.35);
    }

    /* ── Toggle button ── */
    .sidebar-toggle {
      position: absolute; top: 48px; left: 50%;
      transform: translateX(-50%);
      width: 20px; height: 20px; border-radius: 50%;
      background: #0d0d12; border: 1px solid rgba(255,255,255,0.14);
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      color: var(--text-dim); z-index: 20; padding: 0;
      opacity: 0; transition: opacity .18s, background .15s, border-color .15s, color .15s;
    }
    .resize-handle:hover .sidebar-toggle        { opacity: 1; }
    .sidebar.collapsed ~ .resize-handle .sidebar-toggle { opacity: 1; }
    .sidebar-toggle:hover {
      background: rgba(255,255,255,0.08);
      border-color: rgba(255,255,255,0.28); color: var(--text);
    }
    .sidebar-toggle svg {
      transition: transform .28s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .sidebar.collapsed ~ .resize-handle .sidebar-toggle svg {
      transform: rotate(180deg);
    }
  }

  /* ── 移动端模式切换（桌面端隐藏，手机端侧边栏顶部显示）── */
  .mob-mode-toggle {
    display: none;   /* 桌面端不需要，nav 里已有分段控件 */
  }
  @media (max-width: 959px) {
    .mob-mode-toggle {
      display: flex;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 10px;
      padding: 3px; gap: 2px;
      margin-bottom: 18px;
    }
    .mob-mode-btn {
      flex: 1; text-align: center;
      font-size: 13px; font-weight: 500;
      padding: 7px 12px; border-radius: 8px;
      color: rgba(235,235,245,0.45);
      text-decoration: none;
      transition: color .15s, background .15s;
    }
    .mob-mode-btn:hover  { color: rgba(235,235,245,0.75); }
    .mob-mode-btn.active {
      background: rgba(255,255,255,0.12);
      color: rgba(235,235,245,0.90);
    }
  }

  /* ── Section label ── */
  .tree-label {
    font-size: 13.5px; font-weight: 700; letter-spacing: 0.4px;
    text-transform: uppercase; color: rgba(235,235,245,0.28);
    margin-bottom: 6px; padding: 0 6px;
  }

  /* ── 顶级分类之间留间隙 ── */
  .tree-node { margin-bottom: 1px; }
  /* 顶级节点（直接子元素）之间多留空气感 */
  #g-sidebar > .tree-label ~ .tree-node + .tree-node { margin-top: 4px; }

  /* ── Category button（一级分类）── */
  .tree-cat {
    width: 100%; display: flex; align-items: center;
    padding: 5px 8px; border-radius: 6px;
    background: none; border: none; cursor: pointer;
    font-family: var(--font, -apple-system, sans-serif);
    font-size: 13px; font-weight: 600;               /* 一级：semibold */
    color: rgba(235,235,245,0.55);
    letter-spacing: -0.1px;
    transition: background .12s, color .12s;
    text-align: left; gap: 6px;
  }
  .tree-cat:hover { background: rgba(255,255,255,0.06); color: rgba(235,235,245,0.80); }
  .tree-cat.open  { color: rgba(235,235,245,0.90); }

  /* 二级及以下：常规字重，更淡 */
  .tree-cat-sub {
    font-size: 12.5px; font-weight: 500;
    color: rgba(235,235,245,0.40);
  }
  .tree-cat-sub:hover { color: rgba(235,235,245,0.65); }
  .tree-cat-sub.open  { color: rgba(235,235,245,0.78); }

  /* Chevron：与文字同色，更有整体感 */
  .tree-chevron {
    width: 10px; height: 10px; flex-shrink: 0;
    color: currentColor; opacity: 0.5;
    transition: transform .2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .tree-cat.open .tree-chevron { transform: rotate(90deg); opacity: 0.7; }

  .tree-cat-name { flex: 1; }

  /* ── 可折叠容器：无轨道线，纯缩进（Apple Finder 风格）── */
  .tree-children {
    overflow: hidden;
    max-height: 0;
    transition: max-height .26s cubic-bezier(0.4, 0, 0.2, 1);
    padding-left: 18px;   /* 纯缩进，不用 border-left */
  }
  .tree-children.open { max-height: 2000px; }

  /* ── 文章链接 ── */
  .tree-article {
    display: block;
    font-size: 12px; font-weight: 400;
    color: rgba(235,235,245,0.38);
    padding: 4px 6px; border-radius: 5px;
    line-height: 1.4;
    transition: color .12s, background .12s;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .tree-article:hover {
    color: rgba(235,235,245,0.70);
    background: rgba(255,255,255,0.05);
  }
  /* active：蓝底 + 白字（Xcode/Finder 选中标准） */
  .tree-article.active {
    color: #ffffff !important;
    background: rgba(41,151,255,0.22);
    font-weight: 500;
  }

  /* ── Mobile: 触控目标 ≥ 44px（iOS HIG 建议）── */
  @media (max-width: 959px) {
    .tree-cat     { padding: 12px 8px; font-size: 14px; }  /* ~44px */
    .tree-cat-sub { padding: 11px 8px; font-size: 13px; }  /* ~42px */
    .tree-article { padding: 11px 8px; font-size: 13px; }  /* ~42px */
  }
</style>

<script>
  const sidebar  = document.getElementById('g-sidebar')       as HTMLElement | null;
  const handle   = document.getElementById('g-resize-handle') as HTMLElement | null;
  const toggle   = document.getElementById('g-sidebar-toggle')as HTMLElement | null;
  const backdrop = document.getElementById('g-mob-backdrop')  as HTMLElement | null;

  const isDesktop = () => window.matchMedia('(min-width: 960px)').matches;

  // ── Mobile: open / close ──────────────────────────────────────────
  function openMobile() {
    sidebar?.classList.add('mob-open');
    backdrop?.classList.add('mob-open');
    document.body.style.overflow = 'hidden';
  }
  function closeMobile() {
    sidebar?.classList.remove('mob-open');
    backdrop?.classList.remove('mob-open');
    document.body.style.overflow = '';
  }
  (window as any).openMobileSidebar  = openMobile;
  (window as any).closeMobileSidebar = closeMobile;

  backdrop?.addEventListener('click', closeMobile);
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') closeMobile();
  });
  sidebar?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => { if (!isDesktop()) closeMobile(); });
  });

  // ── Always-on: category expand / collapse ─────────────────────────
  if (sidebar) {
    // 展开状态已由 <script is:inline> 在首次绘制前同步还原，此处只处理交互

    function saveOpenCats() {
      const open = Array.from(
        sidebar!.querySelectorAll<HTMLButtonElement>('.tree-cat.open')
      ).map(b => b.dataset.key ?? '').filter(Boolean);
      localStorage.setItem('sidebar-open-cats', JSON.stringify(open));
    }

    // 各分类独立展开/折叠
    sidebar.querySelectorAll<HTMLButtonElement>('.tree-cat').forEach(btn => {
      btn.addEventListener('click', () => {
        const isOpen = btn.classList.contains('open');
        const list   = btn.nextElementSibling as HTMLElement | null;
        btn.classList.toggle('open', !isOpen);
        list?.classList.toggle('open', !isOpen);
        saveOpenCats();
      });
    });

    // 滚动当前文章进视口
    const activeLink = sidebar.querySelector<HTMLElement>('.tree-article.active');
    if (activeLink) {
      requestAnimationFrame(() => activeLink.scrollIntoView({ block: 'nearest' }));
    }
  }

  // ── Desktop only: collapse toggle + drag to resize ───────────────
  if (sidebar && handle && toggle && isDesktop()) {
    if (localStorage.getItem('sidebar-collapsed') === 'true') {
      sidebar.classList.add('collapsed');
      toggle.title = '展开侧边栏';
      toggle.setAttribute('aria-label', '展开侧边栏');
    }
    const savedW = localStorage.getItem('sidebar-width');
    if (savedW && !sidebar.classList.contains('collapsed')) {
      sidebar.style.width = savedW;
    }

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const nowCollapsed = sidebar.classList.toggle('collapsed');
      toggle.title = nowCollapsed ? '展开侧边栏' : '折叠侧边栏';
      toggle.setAttribute('aria-label', nowCollapsed ? '展开侧边栏' : '折叠侧边栏');
      localStorage.setItem('sidebar-collapsed', String(nowCollapsed));
      if (!nowCollapsed) {
        sidebar.style.width = localStorage.getItem('sidebar-width') ?? '240px';
      }
    });

    let dragging = false, startX = 0, startW = 0;
    handle.addEventListener('mousedown', (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest('.sidebar-toggle')) return;
      if (sidebar.classList.contains('collapsed')) {
        sidebar.classList.remove('collapsed');
        localStorage.setItem('sidebar-collapsed', 'false');
      }
      dragging = true; startX = e.clientX; startW = sidebar.offsetWidth;
      handle.classList.add('dragging');
      document.body.style.cursor = 'col-resize';
      document.body.style.userSelect = 'none';
      // 拖拽期间关闭 transition，避免动画追赶鼠标导致迟钝感
      sidebar.style.transition = 'none';
      e.preventDefault();
    });
    document.addEventListener('mousemove', (e: MouseEvent) => {
      if (!dragging) return;
      sidebar.style.width = Math.min(480, Math.max(120, startW + e.clientX - startX)) + 'px';
    });
    document.addEventListener('mouseup', () => {
      if (!dragging) return;
      dragging = false;
      handle.classList.remove('dragging');
      document.body.style.cursor = '';
      document.body.style.userSelect = '';
      // 拖拽结束后恢复 transition（折叠/展开动画仍然有效）
      sidebar.style.transition = '';
      localStorage.setItem('sidebar-width', sidebar.style.width);
    });
  }
</script>
