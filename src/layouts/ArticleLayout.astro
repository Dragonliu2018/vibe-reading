---
import { articles } from '../data/articles';
import Sidebar from '../components/Sidebar.astro';
import SearchModal from '../components/SearchModal.astro';
import NavBar from '../components/NavBar.astro';
import GiscusComments from '../components/GiscusComments.astro';

export interface Props {
  frontmatter: {
    title:        string;
    date:         string;
    category?:    string[];   // 层级路径；最后一项用作徽章
    tags?:        string[];
    description?: string;
    readingTime?: string;
    aiModel?:     string;
  };
  headings?: { depth: number; slug: string; text: string }[];
}

const { frontmatter, headings = [] } = Astro.props;
const { title, date, category, tags = [], description, readingTime, aiModel } = frontmatter;

const base     = import.meta.env.BASE_URL.replace(/\/$/, '');
const catLabel = category?.length ? category[category.length - 1] : '';

// 与首页保持一致：按全站标签首次出现顺序分配颜色，保证相同标签全站同色
const BADGE_PALETTE = [
  { text: '#58a6ff', bg: 'rgba(88,166,255,.12)',  border: 'rgba(88,166,255,.30)'  },
  { text: '#bc8cff', bg: 'rgba(188,140,255,.12)', border: 'rgba(188,140,255,.30)' },
  { text: '#3fb950', bg: 'rgba(63,185,80,.12)',   border: 'rgba(63,185,80,.30)'   },
  { text: '#ff9f0a', bg: 'rgba(255,159,10,.12)',  border: 'rgba(255,159,10,.30)'  },
] as const;
const catCountMap = articles.reduce<Record<string, number>>((acc, a) => {
  const last = a.category[a.category.length - 1];
  if (last) acc[last] = (acc[last] ?? 0) + 1;
  return acc;
}, {});
const allCats = Object.entries(catCountMap).sort((a, b) => b[1] - a[1]).map(([l]) => l);
const catColorMap = new Map(allCats.map((label, i) => [label, BADGE_PALETTE[i % BADGE_PALETTE.length]]));
function badgeStyle(label: string): string {
  const col = catColorMap.get(label) ?? BADGE_PALETTE[0];
  return `color:${col.text};background:${col.bg};border:1px solid ${col.border};`;
}

// Derive slug from URL to highlight current article in sidebar
const pathname    = Astro.url.pathname;
const currentSlug = pathname.replace(/.*\/articles\//, '').replace(/\/$/, '');

// TOC: h2 + h3 only
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · Vibe Reading</title>
  {description && <meta name="description" content={description} />}
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #000000;
      --surface:     rgba(255,255,255,0.03);
      --border:      rgba(255,255,255,0.08);
      --border-lite: rgba(255,255,255,0.05);
      --text:        #f5f5f7;
      --text-muted:  #86868b;
      --text-dim:    #48484a;
      --accent:      #2997ff;
      --code-bg:     #161b22;
      --code-border: #30363d;
      --code-text:   #e6edf3;
      --radius:      16px;
      --radius-sm:   10px;
      --font: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      --mono: ui-monospace, 'SF Mono', SFMono-Regular, 'JetBrains Mono', Menlo, Consolas, monospace;
    }

    html, body { height: 100%; }

    body {
      background: var(--bg);
      background-image: radial-gradient(ellipse 70% 35% at 50% -5%, rgba(41,151,255,0.05) 0%, transparent 65%);
      color: var(--text);
      font-family: var(--font);
      font-size: 16px;
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    @media (max-width: 959px) {
      html, body { height: auto; overflow: visible; }
      body { display: block; }
    }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
    a { color: inherit; text-decoration: none; }

    /* ── Progress bar ── */
    #progress-bar {
      position: fixed; top: 0; left: 0; height: 2px; width: 0%;
      background: var(--accent); z-index: 200; transition: width .1s linear;
    }

    /* ── Root layout ── */
    .layout {
      flex: 1; overflow: hidden;
      display: flex; align-items: stretch;
    }
    @media (max-width: 959px) {
      .layout { flex: none; overflow: visible; display: block; }
    }

    /* ── TOC panel：Categories 右侧，文章左边常驻 ── */
    .article-toc-panel {
      flex-shrink: 0;
      width: 160px;
      height: 100%;
      overflow-y: auto;
      padding: 56px 18px 40px 16px;
      border-left: 1px solid rgba(255,255,255,0.055);
      border-right: 1px solid rgba(255,255,255,0.055);
      scrollbar-width: none;
      transition:
        width .28s cubic-bezier(0.4, 0, 0.2, 1),
        padding .28s cubic-bezier(0.4, 0, 0.2, 1),
        border-color .28s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .article-toc-panel::-webkit-scrollbar { display: none; }
    @media (max-width: 959px) { .article-toc-panel { display: none; } }

    @media (min-width: 960px) {
      .article-toc-panel.collapsed {
        width: 0 !important;
        padding-left: 0; padding-right: 0;
        overflow: hidden;
        border-color: transparent;
      }
    }

    /* ── TOC 折叠 handle（与 Sidebar resize-handle 设计一致）── */
    .toc-handle { display: none; }

    @media (min-width: 960px) {
      .toc-handle {
        display: block; flex-shrink: 0; width: 12px;
        cursor: col-resize; position: relative;
        overflow: visible; background: transparent;
      }
      .toc-handle::before {
        content: ''; position: absolute; left: 5px; top: 0; bottom: 0;
        width: 1px; background: rgba(255,255,255,0.14); transition: background .18s;
      }
      .toc-handle:hover::before  { background: rgba(255,255,255,0.28); }
      .toc-handle.dragging::before { background: rgba(41,151,255,0.7); }

      .toc-toggle {
        position: absolute; top: 48px; left: 50%;
        transform: translateX(-50%);
        width: 20px; height: 20px; border-radius: 50%;
        background: #0d0d12; border: 1px solid rgba(255,255,255,0.14);
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        color: var(--text-dim); z-index: 20; padding: 0;
        opacity: 0;
        transition: opacity .18s, background .15s, border-color .15s, color .15s;
      }
      .toc-handle:hover .toc-toggle        { opacity: 1; }
      /* 折叠时始终显示按钮（提示可展开） */
      .article-toc-panel.collapsed ~ .toc-handle .toc-toggle { opacity: 1; }
      .toc-toggle:hover {
        background: rgba(255,255,255,0.08);
        border-color: rgba(255,255,255,0.28); color: var(--text);
      }
      .toc-toggle svg {
        transition: transform .28s cubic-bezier(0.4, 0, 0.2, 1);
      }
      /* 折叠时箭头翻转（指向右方，表示可展开）*/
      .article-toc-panel.collapsed ~ .toc-handle .toc-toggle svg {
        transform: rotate(180deg);
      }
    }

    /* ── TOC 内容 ── */
    .toc-heading {
      font-size: 9.5px; font-weight: 700; letter-spacing: 0.9px;
      text-transform: uppercase; color: rgba(235,235,245,0.30);
      margin-bottom: 16px; padding-left: 10px;
    }

    .toc-list {
      list-style: none;
      display: flex; flex-direction: column; gap: 0;
    }

    .toc-link {
      display: block;
      font-size: 12px; color: rgba(235,235,245,0.46);
      padding: 4px 4px 4px 10px;
      border-left: 1.5px solid transparent;
      line-height: 1.45;
      transition: color .15s, border-color .15s, background .12s;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      border-radius: 0 5px 5px 0;
    }
    .toc-link:hover {
      color: rgba(235,235,245,0.72);
      border-left-color: rgba(255,255,255,0.18);
      background: rgba(255,255,255,0.04);
    }
    .toc-link.active {
      color: var(--accent);
      border-left-color: var(--accent);
      font-weight: 500;
      background: rgba(41,151,255,0.07);
    }
    /* h3 indented */
    .toc-link.depth-3 {
      padding-left: 18px;
      font-size: 11.5px;
      color: rgba(235,235,245,0.34);
    }
    .toc-link.depth-3:hover  { color: rgba(235,235,245,0.58); }
    .toc-link.depth-3.active { color: var(--accent); }

    /* ── Article scroll panel ── */
    .main-scroll {
      flex: 1; min-width: 0;
      height: 100%; overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.1) transparent;
    }
    .main-scroll::-webkit-scrollbar { width: 4px; }
    .main-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
    @media (max-width: 959px) {
      .main-scroll { flex: none; height: auto; overflow: visible; overflow-x: hidden; }
    }

    /* ── Article column ── */
    .article-col {
      /* 不设 max-width：左侧已有 sidebar + TOC 自然限宽，让正文撑满可用空间 */
      padding: 56px 80px 120px 52px;
    }
    @media (max-width: 959px) {
      .article-col { padding: 36px 6% 80px; overflow-x: hidden; }
    }

    /* ── Article header ── */
    .article-header { margin-bottom: 36px; }

    .article-meta {
      display: flex; align-items: center; gap: 10px;
      flex-wrap: wrap; margin-bottom: 20px;
    }
    .cat-badge { font-size: 11px; font-weight: 600; padding: 2px 9px; border-radius: 20px; }
    .meta-sep  { color: rgba(255,255,255,0.12); }
    .meta-item { font-size: 12.5px; color: var(--text-dim); }

    .article-title {
      font-size: clamp(26px, 4vw, 38px);
      font-weight: 700; letter-spacing: -1.5px; line-height: 1.12;
      color: var(--text); margin-bottom: 16px;
    }
    .article-desc {
      font-size: 16px; color: var(--text-muted);
      line-height: 1.65; margin-bottom: 20px; letter-spacing: -0.1px;
    }
    .article-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag {
      font-size: 11px; font-weight: 500; color: var(--text-dim);
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
      padding: 2px 8px; border-radius: 6px;
      font-family: var(--mono);
    }

    .article-divider { height: 1px; background: rgba(255,255,255,0.06); margin: 36px 0; }

    /* ── Prose ── */
    .prose { color: var(--text-muted); font-size: 16px; }

    .prose h1, .prose h2, .prose h3, .prose h4 { color: var(--text); font-weight: 700; line-height: 1.3; }

    .prose h2 {
      font-size: 22px; letter-spacing: -0.5px;
      margin: 48px 0 18px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    /* divider 之后的第一个标题无需顶部大边距 */
    .prose > :first-child { margin-top: 0 !important; }
    .prose h3 {
      font-size: 17px; letter-spacing: -0.3px; margin: 36px 0 12px;
    }
    .prose h3::before {
      content: '### ';
      font-family: var(--mono); font-size: 13px;
      color: var(--text-dim); font-weight: 400;
    }
    .prose h4 {
      font-size: 14px; font-weight: 600;
      letter-spacing: 0.3px; text-transform: uppercase;
      color: var(--text-dim); margin: 28px 0 10px;
    }

    .prose p { margin-bottom: 18px; line-height: 1.8; }
    .prose strong { color: var(--text); font-weight: 600; }
    .prose em { font-style: italic; }

    .prose a {
      color: var(--accent);
      text-decoration: underline; text-underline-offset: 3px;
      text-decoration-color: rgba(41,151,255,0.35);
      transition: text-decoration-color .15s;
    }
    .prose a:hover { text-decoration-color: var(--accent); }

    .prose :not(pre) > code {
      font-family: var(--mono); font-size: 13px;
      background: rgba(175,184,193,0.12); color: #e6edf3;
      padding: 2px 6px; border-radius: 5px;
    }
    .prose pre {
      background: var(--code-bg); border: 1px solid var(--code-border);
      border-radius: var(--radius-sm); padding: 18px 20px;
      overflow-x: auto; margin: 22px 0;
      font-family: var(--mono); font-size: 13px; line-height: 1.7;
      color: var(--code-text);
    }
    .prose pre code { background: none; border: none; padding: 0; color: inherit; font-size: inherit; }

    /* ── 代码块 macOS 窗口风格（:global 绕开 Astro 作用域）── */
    :global(.prose-code-block) {
      position: relative;
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 12px;
      overflow: hidden;
      margin: 28px 0;
      background: var(--code-bg);
      box-shadow: 0 8px 32px rgba(0,0,0,0.40), 0 2px 8px rgba(0,0,0,0.20);
    }
    :global(.prose-code-block) pre {
      margin: 0 !important;
      border: none !important;
      border-radius: 0 !important;
      background: transparent !important;
    }
    /* 标题栏 */
    :global(.code-header) {
      display: flex; align-items: center;
      padding: 0 14px; height: 40px; gap: 0;
      background: #1c2333;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      user-select: none;
    }
    /* 红黄绿三点 */
    :global(.code-lights) {
      display: flex; align-items: center; gap: 6px; flex-shrink: 0;
    }
    :global(.code-dot) {
      width: 12px; height: 12px; border-radius: 50%;
      border: none; padding: 0; cursor: default; flex-shrink: 0;
      transition: filter .15s;
    }
    :global(.code-dot-red)    { background: #FF5F57; cursor: pointer; }
    :global(.code-dot-yellow) { background: #FFBD2E; }
    :global(.code-dot-green)  { background: #28C840; }
    :global(.code-lights:hover .code-dot) { filter: brightness(1.12); }
    /* 折叠状态：红点变暗（已关闭），绿点变亮（可展开） */
    :global(.prose-code-block.is-collapsed .code-dot-red)   { filter: brightness(0.50); cursor: default; }
    :global(.prose-code-block.is-collapsed .code-dot-green) { filter: brightness(1.20); box-shadow: 0 0 5px rgba(40,200,64,0.45); }
    /* 展开状态：绿点正常，红点可点击 */
    :global(.prose-code-block:not(.is-collapsed) .code-dot-green) { cursor: default; }
    /* 语言标签居中 */
    :global(.code-lang) {
      flex: 1; text-align: center;
      font-family: var(--mono);
      font-size: 11px; font-weight: 500; letter-spacing: 0.4px;
      color: rgba(235,235,245,0.28);
    }
    /* 右侧操作区 */
    :global(.code-actions) { display: flex; align-items: center; gap: 2px; flex-shrink: 0; }
    :global(.code-btn) {
      display: flex; align-items: center; justify-content: center;
      width: 26px; height: 26px; border-radius: 6px;
      background: none; border: none; cursor: pointer; padding: 0;
      color: rgba(235,235,245,0.38);
      transition: background .12s, color .12s;
    }
    :global(.code-btn:hover)  { background: rgba(255,255,255,0.08); color: rgba(235,235,245,0.78); }
    :global(.code-btn:active) { background: rgba(255,255,255,0.12); }
    /* 代码体 */
    :global(.code-body) {
      overflow: hidden;
      transition: max-height .28s cubic-bezier(0.4,0,0.2,1);
    }

    .prose blockquote {
      border-left: 3px solid var(--accent);
      background: rgba(41,151,255,0.05);
      padding: 14px 18px;
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
      margin: 22px 0; color: var(--text-muted);
    }
    .prose blockquote p { margin: 0; }

    .prose ul, .prose ol { padding-left: 22px; margin: 16px 0; }
    .prose ul { list-style: disc; }
    .prose ul li::marker { color: var(--accent); }
    .prose ol { list-style: decimal; }
    .prose ol li::marker { color: var(--accent); font-weight: 600; }
    .prose li { margin-bottom: 7px; line-height: 1.75; }
    .prose li p { margin: 0; }

    .prose table {
      width: 100%; border-collapse: collapse;
      font-size: 14px; margin: 0;
      border: 1px solid var(--code-border);
      border-radius: var(--radius-sm);
    }
    .prose :where(table) { display: block; overflow-x: auto; margin: 22px 0; }
    .prose thead th {
      background: rgba(255,255,255,0.04); color: var(--text-muted);
      font-size: 12px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.4px;
      padding: 10px 16px; text-align: left;
      border-bottom: 1px solid var(--code-border);
    }
    .prose tbody td {
      padding: 10px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      color: var(--text-muted); vertical-align: top;
    }
    .prose tbody tr:last-child td { border-bottom: none; }
    .prose tbody tr:nth-child(even) td { background: rgba(255,255,255,0.015); }
    .prose tbody tr:hover td { background: rgba(255,255,255,0.03); }
    .prose tbody td:first-child { color: var(--text); font-weight: 500; }

    .prose hr { border: none; height: 1px; background: rgba(255,255,255,0.06); margin: 40px 0; }
    .prose img { max-width: 100%; border-radius: var(--radius-sm); margin: 22px 0; }

    /* ── Footer ── */
    .footer {
      border-top: 1px solid rgba(255,255,255,0.05);
      padding: 36px 10%; text-align: center;
      color: var(--text-dim); font-size: 13px; line-height: 1.8;
    }
    .footer a { color: #636366; transition: color .15s; }
    .footer a:hover { color: var(--text-muted); }
    @media (max-width: 680px) {
      .footer { padding: 28px 6%; max-width: none; }
    }

    /* ── 桌面端：回到顶部按钮（仅 ≥960px 显示）── */
    @media (min-width: 960px) {
      .back-to-top {
        position: fixed;
        bottom: 32px; right: 32px; z-index: 155;
        width: 38px; height: 38px; border-radius: 50%;
        background: rgba(14,14,20,0.88);
        backdrop-filter: saturate(180%) blur(20px);
        -webkit-backdrop-filter: saturate(180%) blur(20px);
        border: 1px solid rgba(255,255,255,0.14);
        box-shadow: 0 4px 20px rgba(0,0,0,0.45);
        color: rgba(235,235,245,0.70);
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        opacity: 0; pointer-events: none;
        transform: translateY(10px);
        transition: opacity .22s, transform .22s, background .14s, border-color .14s, color .14s;
      }
      .back-to-top.visible { opacity: 1; pointer-events: auto; transform: translateY(0); }
      .back-to-top:hover   { background: rgba(28,28,36,0.92); border-color: rgba(255,255,255,0.22); color: #f5f5f7; }
      .back-to-top:active  { transform: scale(.90); }
    }

    /* ══ 移动端目录：左侧半隐藏 tab + 侧滑面板 ═════════════════ */
    .mob-toc-tab,
    .mob-toc-backdrop,
    .mob-toc-panel { display: none; }

    @media (max-width: 959px) {
      /* ── 右下角圆形按钮 ── */
      .mob-toc-tab {
        display: flex;
        position: fixed;
        bottom: 32px; right: 20px;
        z-index: 163;
        width: 44px; height: 44px;
        border-radius: 50%;
        align-items: center; justify-content: center;
        background: rgba(14,14,20,0.88);
        backdrop-filter: saturate(180%) blur(20px);
        -webkit-backdrop-filter: saturate(180%) blur(20px);
        border: 1px solid rgba(255,255,255,0.14);
        box-shadow: 0 4px 20px rgba(0,0,0,0.45);
        color: rgba(235,235,245,0.70);
        cursor: pointer;
        transition: background .14s, border-color .14s, color .14s;
      }
      .mob-toc-tab:active {
        background: rgba(28,28,36,0.95);
        color: #f5f5f7;
      }
      /* 双图标层：目录 ↔ 回顶切换 */
      .mob-toc-tab .tab-icon {
        position: absolute;
        display: flex; align-items: center; justify-content: center;
        transition: opacity .22s cubic-bezier(0.4,0,0.2,1),
                    transform .22s cubic-bezier(0.4,0,0.2,1);
      }
      .mob-toc-tab .tab-icon-top {
        opacity: 0; transform: scale(0.6) translateY(3px);
      }
      /* 滚过阈值后切换至"回顶"状态 */
      .mob-toc-tab[data-state="top"] .tab-icon-toc {
        opacity: 0; transform: scale(0.6) translateY(-3px);
      }
      .mob-toc-tab[data-state="top"] .tab-icon-top {
        opacity: 1; transform: scale(1) translateY(0);
      }

      /* ── 遮罩 ── */
      .mob-toc-backdrop {
        display: block;
        position: fixed; inset: 0; z-index: 161;
        background: rgba(0,0,0,0.50);
        backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px);
        opacity: 0; pointer-events: none;
        transition: opacity .26s ease;
      }
      .mob-toc-backdrop.open { opacity: 1; pointer-events: auto; }

      /* ── 左侧滑入面板 ── */
      .mob-toc-panel {
        display: flex; flex-direction: column;
        position: fixed;
        top: 0; left: 0; bottom: 0; z-index: 162;
        width: min(288px, 82vw);
        background: #09090e;
        border-right: 1px solid rgba(255,255,255,0.07);
        box-shadow: 10px 0 40px rgba(0,0,0,0.55);
        overflow: hidden;
        transform: translateX(-100%);
        transition: transform .3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .mob-toc-panel.open { transform: translateX(0); }

      /* 面板头部 */
      .mob-toc-panel-head {
        display: flex; align-items: center; justify-content: space-between;
        flex-shrink: 0;
        padding: 60px 20px 12px 24px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
      }
      .mob-toc-panel-title {
        font-size: 10px; font-weight: 700; letter-spacing: 0.9px;
        text-transform: uppercase; color: rgba(235,235,245,0.30);
      }
      .mob-toc-panel-close {
        width: 28px; height: 28px; border-radius: 50%;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.09);
        display: flex; align-items: center; justify-content: center;
        color: rgba(235,235,245,0.45);
        cursor: pointer; padding: 0; flex-shrink: 0;
        transition: background .12s, color .12s;
      }
      .mob-toc-panel-close:active {
        background: rgba(255,255,255,0.10); color: rgba(235,235,245,0.80);
      }

      /* 目录列表 */
      .mob-toc-list {
        list-style: none; flex: 1;
        overflow-y: auto; -webkit-overflow-scrolling: touch;
        padding: 8px 12px max(20px, env(safe-area-inset-bottom, 0px));
      }
      .mob-toc-link {
        display: flex; align-items: center;
        min-height: 44px; padding: 8px 12px;
        border-radius: 10px;
        font-size: 14px; color: rgba(235,235,245,0.58);
        text-decoration: none;
        transition: color .12s, background .12s;
      }
      .mob-toc-link:active { background: rgba(255,255,255,0.06); }
      .mob-toc-link.active {
        color: var(--accent);
        background: rgba(41,151,255,0.08);
        font-weight: 500;
      }
      .mob-toc-link.depth-3 {
        padding-left: 28px;
        font-size: 13px;
        color: rgba(235,235,245,0.42);
      }
      .mob-toc-link.depth-3.active { color: var(--accent); }
    }
  </style>
</head>
<body>

  <div id="progress-bar" data-pagefind-ignore="all"></div>

  <NavBar mode="articles" showBack={true} />

  <div class="layout">

    <!-- 左侧：分类树 -->
    <Sidebar currentSlug={currentSlug} />

    <!-- 常驻目录：Categories 右侧，文章左边 -->
    {tocHeadings.length > 0 && (
      <>
        <aside id="g-toc-panel" class="article-toc-panel" data-pagefind-ignore="all">
          <p class="toc-heading">目录</p>
          <ul class="toc-list">
            {tocHeadings.map(h => (
              <li>
                <a
                  href={`#${h.slug}`}
                  class:list={['toc-link', `depth-${h.depth}`]}
                  title={h.text}
                >{h.text}</a>
              </li>
            ))}
          </ul>
        </aside>

        <!-- TOC 折叠 handle -->
        <div id="g-toc-handle" class="toc-handle">
          <button id="g-toc-toggle" class="toc-toggle"
                  title="折叠目录" aria-label="折叠目录">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
              <path d="M6.5 2L3.5 5L6.5 8" stroke="currentColor" stroke-width="1.4"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </>
    )}

    <!-- 正文 -->
    <div class="main-scroll">
      <div class="article-col">

        <header class="article-header">
          <div class="article-meta">
            {catLabel && (
              <span class="cat-badge" style={badgeStyle(catLabel)}>
                {catLabel}
              </span>
            )}
            {date        && <><span class="meta-sep">·</span><span class="meta-item">{date}</span></>}
            {readingTime && <><span class="meta-sep">·</span><span class="meta-item">{readingTime}</span></>}
            {aiModel     && <><span class="meta-sep">·</span><span class="meta-item">{aiModel}</span></>}
          </div>

          <h1 class="article-title" data-pagefind-meta="title">{title}</h1>
          {description && <p class="article-desc">{description}</p>}

          {tags.length > 0 && (
            <div class="article-tags">
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </header>

        <div class="article-divider"></div>

        <article class="prose">
          <slot />
        </article>

        <GiscusComments />

      </div>

      <footer class="footer" data-pagefind-ignore="all">
        Vibe Reading · AI-drafted · Human-reviewed &nbsp;·&nbsp;
        <a href={`${base}/`}>← 返回首页</a> &nbsp;·&nbsp;
        <a href="https://github.com/Dragonliu2018/vibe-reading" target="_blank" rel="noopener">GitHub</a>
      </footer>
    </div>

  </div>

  <script>
    const bar    = document.getElementById('progress-bar')!;
    const scroll = document.querySelector<HTMLElement>('.main-scroll');

    // ── 阅读进度条 + 桌面端回到顶部 ─────────────────────────────
    const backToTop = document.getElementById('back-to-top') as HTMLElement | null;
    if (scroll) {
      scroll.addEventListener('scroll', () => {
        const top = scroll.scrollTop;
        bar.style.width = (top / (scroll.scrollHeight - scroll.clientHeight) * 100) + '%';
        if (isDesktop()) backToTop?.classList.toggle('visible', top > 300);
      });
    }
    backToTop?.addEventListener('click', () => {
      scroll?.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // ── TOC：点击平滑滚动（TOC 在 main-scroll 外，需手动处理）──
    const tocLinks   = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    const headingEls = document.querySelectorAll<HTMLElement>('article h2[id], article h3[id]');

    tocLinks.forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault();
        const id = link.getAttribute('href')?.slice(1);
        const target = id ? document.getElementById(id) : null;
        if (!target || !scroll) return;
        const containerTop = scroll.getBoundingClientRect().top;
        const targetTop    = target.getBoundingClientRect().top;
        scroll.scrollBy({ top: targetTop - containerTop - 68, behavior: 'smooth' });
      });
    });

    // ── TOC：折叠 / 展开 ───────────────────────────────────────
    const tocPanel  = document.getElementById('g-toc-panel') as HTMLElement | null;
    const tocToggle = document.getElementById('g-toc-toggle') as HTMLButtonElement | null;
    const isDesktop = () => window.matchMedia('(min-width: 960px)').matches;

    const tocHandle = document.getElementById('g-toc-handle') as HTMLElement | null;

    if (tocPanel && tocHandle && tocToggle && isDesktop()) {
      // 还原折叠状态
      if (localStorage.getItem('toc-collapsed') === 'true') {
        tocPanel.classList.add('collapsed');
        tocToggle.title = '展开目录';
        tocToggle.setAttribute('aria-label', '展开目录');
      }
      // 还原宽度
      const savedW = localStorage.getItem('toc-width');
      if (savedW && !tocPanel.classList.contains('collapsed')) {
        tocPanel.style.width = savedW;
      }

      // 折叠 / 展开按钮
      tocToggle.addEventListener('click', e => {
        e.stopPropagation();
        const nowCollapsed = tocPanel.classList.toggle('collapsed');
        tocToggle.title = nowCollapsed ? '展开目录' : '折叠目录';
        tocToggle.setAttribute('aria-label', nowCollapsed ? '展开目录' : '折叠目录');
        localStorage.setItem('toc-collapsed', String(nowCollapsed));
        if (!nowCollapsed) {
          tocPanel.style.width = localStorage.getItem('toc-width') ?? '160px';
        }
      });

      // 拖拽 resize
      let dragging = false, startX = 0, startW = 0;
      tocHandle.addEventListener('mousedown', (e: MouseEvent) => {
        if ((e.target as HTMLElement).closest('.toc-toggle')) return;
        // 折叠时拖拽先展开
        if (tocPanel.classList.contains('collapsed')) {
          tocPanel.classList.remove('collapsed');
          localStorage.setItem('toc-collapsed', 'false');
        }
        dragging = true; startX = e.clientX; startW = tocPanel.offsetWidth;
        tocHandle.classList.add('dragging');
        document.body.style.cursor    = 'col-resize';
        document.body.style.userSelect = 'none';
        tocPanel.style.transition = 'none';   // 拖拽时关闭动画
        e.preventDefault();
      });
      document.addEventListener('mousemove', (e: MouseEvent) => {
        if (!dragging) return;
        const w = Math.min(320, Math.max(80, startW + e.clientX - startX));
        tocPanel.style.width = w + 'px';
      });
      document.addEventListener('mouseup', () => {
        if (!dragging) return;
        dragging = false;
        tocHandle.classList.remove('dragging');
        document.body.style.cursor    = '';
        document.body.style.userSelect = '';
        tocPanel.style.transition = '';       // 恢复动画
        localStorage.setItem('toc-width', tocPanel.style.width);
      });
    }

    // ── 移动端目录：左侧 tab + 侧滑面板 ──────────────────────

    const mobTab      = document.getElementById('mob-toc-tab')      as HTMLElement | null;
    const mobBackdrop = document.getElementById('mob-toc-backdrop') as HTMLElement | null;
    const mobPanel    = document.getElementById('mob-toc-panel')    as HTMLElement | null;
    const mobClose    = document.getElementById('mob-toc-close')    as HTMLElement | null;
    const mobLinks    = document.querySelectorAll<HTMLAnchorElement>('.mob-toc-link');

    function openMobToc() {
      mobBackdrop?.classList.add('open');
      mobPanel?.classList.add('open');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        mobPanel?.querySelector<HTMLElement>('.mob-toc-link.active')
          ?.scrollIntoView({ block: 'nearest' });
      });
    }
    function closeMobToc() {
      mobBackdrop?.classList.remove('open');
      mobPanel?.classList.remove('open');
      document.body.style.overflow = '';
    }
    // 滚动阈值：3 个屏幕高度，手动滑动代价大时才切为「回顶」
    const TOC_THRESHOLD = window.innerHeight * 3;
    window.addEventListener('scroll', () => {
      if (isDesktop() || !mobTab) return;
      const scrolled = window.scrollY > TOC_THRESHOLD;
      mobTab.dataset.state  = scrolled ? 'top' : 'toc';
      mobTab.ariaLabel      = scrolled ? '回到顶部' : '查看目录';
    }, { passive: true });

    mobTab?.addEventListener('click', () => {
      if (mobTab.dataset.state === 'top') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        openMobToc();
      }
    });
    mobClose?.addEventListener('click', closeMobToc);
    mobBackdrop?.addEventListener('click', closeMobToc);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMobToc(); });

    mobLinks.forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault();
        const id = link.dataset.id;
        closeMobToc();
        const target = id ? document.getElementById(id) : null;
        if (target) {
          setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 300);
        }
      });
    });

    // ── TOC：高亮当前章节（桌面 + 移动共用）────────────────────
    if (headingEls.length) {
      const setActive = (id: string) => {
        tocLinks.forEach(a => a.classList.toggle('active', a.getAttribute('href') === `#${id}`));
        mobLinks.forEach(a => a.classList.toggle('active', a.dataset.id === id));
      };

      // 桌面端：root = .main-scroll；移动端：root = null（视口）
      const obsRoot   = isDesktop() ? scroll : null;
      const obsMargin = '-52px 0px -55% 0px';

      const obs = new IntersectionObserver(entries => {
        for (const e of entries) {
          if (e.isIntersecting) setActive(e.target.getAttribute('id') ?? '');
        }
      }, { root: obsRoot, rootMargin: obsMargin });

      headingEls.forEach(h => obs.observe(h));
    }

    // ── 代码块增强：语言标签 + 折叠 + 一键复制 ─────────────────
    (function enhanceCodeBlocks() {
      const COLLAPSED_H = 0;     // 折叠后完全隐藏代码内容

      const SVG_COPY = `<svg width="13" height="13" viewBox="0 0 16 16" fill="none">
        <rect x="5" y="5" width="9" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
        <path d="M5 4V3a1.5 1.5 0 0 1 1.5-1.5h6A1.5 1.5 0 0 1 14 3v8.5"
              stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>`;
      const SVG_CHECK = `<svg width="13" height="13" viewBox="0 0 16 16" fill="none">
        <path d="M2 8l4.5 4.5 8-8" stroke="#3fb950" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>`;

      document.querySelectorAll<HTMLElement>('.prose pre').forEach(pre => {
        const code = pre.querySelector('code');
        const lang = pre.getAttribute('data-language')
          ?? [...(code?.classList ?? [])].find(c => c.startsWith('language-'))?.slice(9)
          ?? '';

        // ── DOM 结构 ──
        const wrapper = document.createElement('div');
        wrapper.className = 'prose-code-block';

        // 标题栏
        const header = document.createElement('div');
        header.className = 'code-header';

        // 红黄绿三点
        const lights = document.createElement('div');
        lights.className = 'code-lights';
        const dotRed    = document.createElement('button');
        const dotYellow = document.createElement('span');
        const dotGreen  = document.createElement('button');
        dotRed.className    = 'code-dot code-dot-red';
        dotYellow.className = 'code-dot code-dot-yellow';
        dotGreen.className  = 'code-dot code-dot-green';
        dotRed.title        = '折叠代码';
        dotGreen.title      = '展开代码';
        lights.append(dotRed, dotYellow, dotGreen);

        // 语言标签（居中）
        const langEl = document.createElement('span');
        langEl.className  = 'code-lang';
        langEl.textContent = lang || 'plaintext';

        // 右侧：复制按钮
        const actions = document.createElement('div');
        actions.className = 'code-actions';
        const cpBtn = document.createElement('button');
        cpBtn.className = 'code-btn';
        cpBtn.title     = '复制代码';
        cpBtn.innerHTML = SVG_COPY;
        actions.appendChild(cpBtn);

        header.append(lights, langEl, actions);

        // 代码体
        const body = document.createElement('div');
        body.className = 'code-body';

        pre.parentNode!.insertBefore(wrapper, pre);
        body.appendChild(pre);
        wrapper.append(header, body);
        pre.style.background = 'transparent';

        // ── 红点 = 折叠（关闭），绿点 = 展开（还原）──
        let collapsed = false;

        const collapse = () => {
          if (collapsed) return;
          collapsed = true;
          wrapper.classList.add('is-collapsed');
          body.style.maxHeight = body.scrollHeight + 'px';
          requestAnimationFrame(() => { body.style.maxHeight = COLLAPSED_H + 'px'; });
        };

        const expand = () => {
          if (!collapsed) return;
          collapsed = false;
          wrapper.classList.remove('is-collapsed');
          body.style.maxHeight = body.scrollHeight + 'px';
          body.addEventListener('transitionend', () => {
            if (!collapsed) body.style.maxHeight = '';
          }, { once: true });
        };

        dotRed.addEventListener('click', collapse);
        dotGreen.addEventListener('click', expand);

        // ── 复制 ──
        cpBtn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(pre.innerText);
            cpBtn.innerHTML = SVG_CHECK;
            cpBtn.style.color = '#3fb950';
            setTimeout(() => { cpBtn.innerHTML = SVG_COPY; cpBtn.style.color = ''; }, 1800);
          } catch { cpBtn.title = '复制失败'; }
        });
      });
    })();
  </script>

  <!-- 桌面端：回到顶部 -->
  <button id="back-to-top" class="back-to-top" aria-label="回到顶部" title="回到顶部" data-pagefind-ignore="all">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M8 13V3M3 8l5-5 5 5" stroke="currentColor" stroke-width="1.6"
            stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <!-- 移动端目录：左侧半隐藏 tab + 侧滑面板 -->
  {tocHeadings.length > 0 && (
    <>
      <!-- 左侧半隐藏 Tab -->
      <button id="mob-toc-tab" class="mob-toc-tab" data-state="toc"
              aria-label="查看目录" data-pagefind-ignore="all">
        <!-- 目录图标（Notion 风格大纲线）-->
        <span class="tab-icon tab-icon-toc" aria-hidden="true">
          <svg width="14" height="13" viewBox="0 0 14 13" fill="none">
            <path d="M0 1h14"      stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M2.5 5h11.5"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M2.5 9h9"     stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M0 13h14"     stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
        </span>
        <!-- 回顶图标（向上箭头）-->
        <span class="tab-icon tab-icon-top" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M8 13V3M3 8l5-5 5 5" stroke="currentColor" stroke-width="1.6"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </button>

      <!-- 遮罩 -->
      <div id="mob-toc-backdrop" class="mob-toc-backdrop" aria-hidden="true"></div>

      <!-- 侧滑面板 -->
      <div id="mob-toc-panel" class="mob-toc-panel" role="dialog" aria-label="文章目录" data-pagefind-ignore="all">
        <div class="mob-toc-panel-head">
          <p class="mob-toc-panel-title">目录</p>
          <button id="mob-toc-close" class="mob-toc-panel-close" aria-label="关闭目录">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M1 1l8 8M9 1L1 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
        <ul class="mob-toc-list">
          {tocHeadings.map(h => (
            <li>
              <a href={`#${h.slug}`}
                 class:list={['mob-toc-link', `depth-${h.depth}`]}
                 data-id={h.slug}
                 title={h.text}>
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </>
  )}

  <SearchModal />

</body>
</html>
