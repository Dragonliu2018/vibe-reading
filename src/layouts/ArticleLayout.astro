---
import { CATEGORY_LABEL, CATEGORY_COLOR, type Category } from '../data/articles';

export interface Props {
  frontmatter: {
    title:       string;
    date:        string;
    category?:   Category;
    tags?:       string[];
    description?: string;
    readingTime?: string;
    aiModel?:    string;
  };
}

const { frontmatter } = Astro.props;
const { title, date, category, tags = [], description, readingTime, aiModel } = frontmatter;

const base  = import.meta.env.BASE_URL.replace(/\/$/, '');
const color = category ? CATEGORY_COLOR[category] : null;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · Vibe Reading</title>
  {description && <meta name="description" content={description} />}
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <style>
    /* ─── Reset & Base ────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #0d1117;
      --bg-card:     #161b22;
      --bg-card2:    #1c2230;
      --bg-code:     #0e1521;
      --border:      #30363d;
      --border-lite: #21262d;
      --text:        #e6edf3;
      --text-muted:  #8b949e;
      --text-dim:    #6e7681;
      --accent:      #f97316;
      --accent2:     #fb923c;
      --accent-glow: rgba(249,115,22,.15);
      --radius:      10px;
      --radius-sm:   6px;
      --font: 'Inter', 'PingFang SC', 'Microsoft YaHei', system-ui, sans-serif;
      --mono: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 15px;
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

    a { color: inherit; text-decoration: none; }

    /* ─── Nav ─────────────────────────────────────────── */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(13,17,23,.88);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-lite);
      padding: 0 40px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 16px;
      font-weight: 700;
    }

    .nav-logo-text {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .nav-right { display: flex; align-items: center; gap: 10px; }

    .nav-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: var(--text-muted);
      background: var(--bg-card);
      border: 1px solid var(--border);
      padding: 5px 14px;
      border-radius: 20px;
      transition: all .15s;
    }

    .nav-btn:hover { color: var(--text); border-color: var(--accent); }

    /* ─── Article Layout ──────────────────────────────── */
    .article-wrap {
      max-width: 760px;
      margin: 0 auto;
      padding: 56px 40px 120px;
    }

    /* ─── Article Header ──────────────────────────────── */
    .article-header { margin-bottom: 48px; }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 20px;
    }

    .cat-badge {
      display: inline-flex;
      align-items: center;
      font-size: 11.5px;
      font-weight: 600;
      padding: 3px 11px;
      border-radius: 20px;
    }

    .meta-item {
      font-size: 13px;
      color: var(--text-dim);
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .article-title {
      font-size: 36px;
      font-weight: 800;
      letter-spacing: -1px;
      line-height: 1.2;
      color: var(--text);
      margin-bottom: 16px;
    }

    .article-desc {
      font-size: 16px;
      color: var(--text-muted);
      line-height: 1.7;
      margin-bottom: 20px;
    }

    .article-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .tag {
      font-size: 11.5px;
      font-weight: 500;
      color: var(--text-dim);
      background: var(--bg-card);
      border: 1px solid var(--border-lite);
      padding: 2px 9px;
      border-radius: 20px;
      font-family: var(--mono);
    }

    .article-divider {
      height: 1px;
      background: var(--border-lite);
      margin: 36px 0;
    }

    /* ─── Prose（Markdown 正文样式）─────────────────────── */
    .prose { color: var(--text-muted); }

    /* 标题 */
    .prose h1,
    .prose h2,
    .prose h3,
    .prose h4 {
      color: var(--text);
      font-weight: 700;
      line-height: 1.35;
    }

    .prose h1 {
      font-size: 28px;
      letter-spacing: -.5px;
      margin: 48px 0 20px;
    }

    .prose h2 {
      font-size: 22px;
      letter-spacing: -.3px;
      margin: 40px 0 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border-lite);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .prose h2::before {
      content: '';
      display: block;
      width: 3px;
      height: 20px;
      background: var(--accent);
      border-radius: 2px;
      flex-shrink: 0;
    }

    .prose h3 {
      font-size: 17px;
      margin: 32px 0 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .prose h3::before {
      content: '';
      display: block;
      width: 3px;
      height: 16px;
      background: rgba(249,115,22,.5);
      border-radius: 2px;
      flex-shrink: 0;
    }

    .prose h4 {
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .5px;
      color: var(--text-muted);
      margin: 24px 0 10px;
    }

    /* 段落 & 文字 */
    .prose p { margin-bottom: 16px; line-height: 1.8; }
    .prose strong { color: var(--text); font-weight: 600; }
    .prose em { color: var(--accent2); font-style: italic; }

    /* 链接 */
    .prose a {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: rgba(249,115,22,.4);
      transition: text-decoration-color .15s;
    }
    .prose a:hover { text-decoration-color: var(--accent); }

    /* 行内代码 */
    .prose :not(pre) > code {
      font-family: var(--mono);
      font-size: 12.5px;
      background: rgba(249,115,22,.1);
      border: 1px solid rgba(249,115,22,.2);
      color: var(--accent2);
      padding: 1px 6px;
      border-radius: 4px;
    }

    /* 代码块 */
    .prose pre {
      background: var(--bg-code);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px 22px;
      overflow-x: auto;
      margin: 20px 0;
      font-family: var(--mono);
      font-size: 13px;
      line-height: 1.7;
      color: #c9d1d9;
    }

    .prose pre code {
      background: none;
      border: none;
      padding: 0;
      color: inherit;
      font-size: inherit;
    }

    /* 引用块 */
    .prose blockquote {
      border-left: 3px solid var(--accent);
      background: var(--accent-glow);
      padding: 14px 18px;
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
      margin: 20px 0;
      color: var(--text-muted);
      font-style: italic;
    }

    .prose blockquote p { margin: 0; }

    /* 列表 */
    .prose ul,
    .prose ol {
      padding-left: 24px;
      margin: 14px 0;
    }

    .prose ul { list-style: none; }

    .prose ul li::before {
      content: '▸';
      color: var(--accent);
      font-size: 11px;
      margin-left: -18px;
      margin-right: 8px;
    }

    .prose ol { list-style: decimal; }
    .prose ol li::marker { color: var(--accent); font-weight: 600; }

    .prose li {
      margin-bottom: 6px;
      color: var(--text-muted);
      line-height: 1.7;
    }

    .prose li p { margin: 0; }

    /* 表格 */
    .prose table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13.5px;
      margin: 20px 0;
    }

    .prose thead th {
      background: var(--bg-card2);
      color: var(--text-muted);
      font-size: 11.5px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .4px;
      padding: 10px 16px;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    .prose tbody td {
      padding: 9px 16px;
      border-bottom: 1px solid var(--border-lite);
      color: var(--text-muted);
      vertical-align: top;
    }

    .prose tbody tr:hover td { background: rgba(255,255,255,.02); }
    .prose tbody td:first-child { color: var(--text); font-weight: 500; }

    /* 分割线 */
    .prose hr {
      border: none;
      height: 1px;
      background: var(--border-lite);
      margin: 36px 0;
    }

    /* 图片 */
    .prose img {
      max-width: 100%;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      margin: 20px 0;
    }

    /* ─── Footer ──────────────────────────────────────── */
    .footer {
      border-top: 1px solid var(--border-lite);
      padding: 32px 40px;
      text-align: center;
      color: var(--text-dim);
      font-size: 12.5px;
      line-height: 1.8;
    }

    .footer a { color: var(--accent); }

    /* ─── Responsive ──────────────────────────────────── */
    @media (max-width: 640px) {
      .nav { padding: 0 20px; }
      .article-wrap { padding: 36px 20px 80px; }
      .article-title { font-size: 26px; }
      .footer { padding: 24px 20px; }
    }
  </style>
</head>
<body>

  <!-- Nav -->
  <nav class="nav">
    <a href={`${base}/`} class="nav-logo">
      <span>🔥</span>
      <span class="nav-logo-text">Vibe Reading</span>
    </a>
    <div class="nav-right">
      <a href={`${base}/`} class="nav-btn">← 返回首页</a>
      <a
        href="https://github.com/Dragonliu2018/vibe-reading"
        target="_blank"
        rel="noopener"
        class="nav-btn"
      >GitHub</a>
    </div>
  </nav>

  <!-- Article -->
  <div class="article-wrap">

    <!-- Header -->
    <header class="article-header">
      <div class="article-meta">
        {color && category && (
          <span
            class="cat-badge"
            style={`color:${color.text};background:${color.bg};border:1px solid ${color.border};`}
          >
            {CATEGORY_LABEL[category]}
          </span>
        )}
        {date && <span class="meta-item">📅 {date}</span>}
        {readingTime && <span class="meta-item">⏱ {readingTime}</span>}
        {aiModel && <span class="meta-item">🤖 {aiModel}</span>}
      </div>

      <h1 class="article-title">{title}</h1>

      {description && <p class="article-desc">{description}</p>}

      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="article-divider"></div>

    <!-- Markdown 正文 -->
    <article class="prose">
      <slot />
    </article>

  </div>

  <!-- Footer -->
  <footer class="footer">
    <p>Vibe Reading · AI 生成 · 人工 Review</p>
    <p style="margin-top:6px;">
      <a href={`${base}/`}>← 返回首页</a>
      &nbsp;·&nbsp;
      <a href="https://github.com/Dragonliu2018/vibe-reading" target="_blank" rel="noopener">GitHub</a>
    </p>
  </footer>

</body>
</html>
