---
import { CATEGORY_LABEL, CATEGORY_COLOR, type Category } from '../data/articles';
import Sidebar from '../components/Sidebar.astro';
import SearchModal from '../components/SearchModal.astro';

export interface Props {
  frontmatter: {
    title:        string;
    date:         string;
    category?:    Category;
    tags?:        string[];
    description?: string;
    readingTime?: string;
    aiModel?:     string;
  };
  headings?: { depth: number; slug: string; text: string }[];
}

const { frontmatter, headings = [] } = Astro.props;
const { title, date, category, tags = [], description, readingTime, aiModel } = frontmatter;

const base  = import.meta.env.BASE_URL.replace(/\/$/, '');
const color = category ? CATEGORY_COLOR[category] : null;

// Derive slug from URL to highlight current article in sidebar
const pathname    = Astro.url.pathname;
const currentSlug = pathname.replace(/.*\/articles\//, '').replace(/\/$/, '');

// TOC: h2 + h3 only
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · Vibe Reading</title>
  {description && <meta name="description" content={description} />}
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #000000;
      --surface:     rgba(255,255,255,0.03);
      --border:      rgba(255,255,255,0.08);
      --border-lite: rgba(255,255,255,0.05);
      --text:        #f5f5f7;
      --text-muted:  #86868b;
      --text-dim:    #48484a;
      --accent:      #2997ff;
      --code-bg:     #161b22;
      --code-border: #30363d;
      --code-text:   #e6edf3;
      --radius:      16px;
      --radius-sm:   10px;
      --font: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      --mono: ui-monospace, 'SF Mono', SFMono-Regular, 'JetBrains Mono', Menlo, Consolas, monospace;
    }

    html, body { height: 100%; }

    body {
      background: var(--bg);
      background-image: radial-gradient(ellipse 70% 35% at 50% -5%, rgba(41,151,255,0.05) 0%, transparent 65%);
      color: var(--text);
      font-family: var(--font);
      font-size: 16px;
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    @media (max-width: 959px) {
      html, body { height: auto; overflow: visible; }
      body { display: block; }
    }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
    a { color: inherit; text-decoration: none; }

    /* ── Progress bar ── */
    #progress-bar {
      position: fixed; top: 0; left: 0; height: 2px; width: 0%;
      background: var(--accent); z-index: 200; transition: width .1s linear;
    }

    /* ── Nav ── */
    .nav {
      flex-shrink: 0;
      position: sticky; top: 0; z-index: 100;
      background: rgba(0,0,0,0.75);
      backdrop-filter: saturate(180%) blur(20px);
      -webkit-backdrop-filter: saturate(180%) blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      height: 52px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 48px;
    }
    .nav-logo {
      display: flex; align-items: center; gap: 9px;
      font-size: 15px; font-weight: 600; letter-spacing: -0.3px;
    }
    .nav-logo-icon {
      width: 22px; height: 22px; border-radius: 7px;
      background: linear-gradient(135deg, #2997ff 0%, #30d158 100%);
      display: flex; align-items: center; justify-content: center;
    }
    .nav-right { display: flex; gap: 6px; }
    .nav-pill {
      font-size: 13px; font-family: var(--font); color: var(--text-muted);
      padding: 5px 14px; border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      transition: color .15s, border-color .15s, background .15s;
      display: flex; align-items: center; gap: 5px;
      cursor: pointer; text-decoration: none;
    }
    .nav-pill:hover { color: var(--text); border-color: rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); }

    .mob-menu-btn {
      display: none; align-items: center; justify-content: center;
      width: 40px; height: 40px; border-radius: 10px;
      background: none; border: none; cursor: pointer;
      color: var(--text-muted); transition: color .15s, background .15s;
      flex-shrink: 0;
    }
    .mob-menu-btn:hover { color: var(--text); background: rgba(255,255,255,0.06); }
    @media (max-width: 959px) { .mob-menu-btn { display: flex; } }

    .search-btn {
      display: flex; align-items: center; gap: 6px;
      font-size: 13px; color: var(--text-muted);
      padding: 5px 12px; border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      cursor: pointer; white-space: nowrap;
      transition: color .15s, border-color .15s, background .15s;
      font-family: var(--font);
    }
    .search-btn:hover { color: var(--text); border-color: rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); }
    .search-btn-hint { font-size: 11px; color: var(--text-dim); }
    @media (max-width: 680px) { .search-btn-hint { display: none; } }

    /* ── Two-column layout ── */
    .layout {
      flex: 1;
      overflow: hidden;
      display: flex;
      align-items: stretch;
    }
    @media (max-width: 959px) {
      .layout { flex: none; overflow: visible; display: block; }
    }

    /* ── Right: article scroll panel ── */
    .main-scroll {
      flex: 1; min-width: 0;
      height: 100%; overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.1) transparent;
    }
    .main-scroll::-webkit-scrollbar { width: 4px; }
    .main-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
    @media (max-width: 959px) {
      .main-scroll { flex: none; height: auto; overflow: visible; }
    }

    /* ── Article + TOC flex row ── */
    .article-with-toc {
      display: flex;
      align-items: flex-start;
    }

    /* ── Article column ── */
    .article-col {
      flex: 1;
      min-width: 0;
      max-width: 780px;
      padding: 56px 48px 120px 52px;
    }
    @media (max-width: 959px) {
      .article-col { padding: 36px 6% 80px; max-width: none; }
    }

    /* ── Right TOC panel ── */
    .toc-panel {
      flex-shrink: 0;
      width: 196px;
      position: sticky;
      top: 0;
      max-height: 100vh;
      overflow-y: auto;
      padding: 56px 20px 40px 20px;
      border-left: 1px solid rgba(255,255,255,0.06);
      scrollbar-width: none;
    }
    .toc-panel::-webkit-scrollbar { display: none; }

    /* Hide TOC when viewport is too narrow */
    @media (max-width: 1260px) { .toc-panel { display: none; } }

    .toc-heading {
      font-size: 10px; font-weight: 700; letter-spacing: 1px;
      text-transform: uppercase; color: var(--text-dim);
      margin-bottom: 12px;
    }

    .toc-list {
      list-style: none;
      display: flex; flex-direction: column; gap: 1px;
    }

    .toc-link {
      display: block;
      font-size: 12.5px; color: var(--text-dim);
      padding: 3.5px 0 3.5px 10px;
      border-left: 1.5px solid transparent;
      line-height: 1.45; text-decoration: none;
      transition: color .15s, border-color .15s;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .toc-link:hover { color: var(--text-muted); border-left-color: rgba(255,255,255,0.18); }
    .toc-link.active { color: var(--accent); border-left-color: var(--accent); font-weight: 500; }

    /* h3 indented */
    .toc-link.depth-3 { padding-left: 20px; font-size: 12px; }

    /* ── Article header ── */
    .article-header { margin-bottom: 48px; }

    .article-meta {
      display: flex; align-items: center; gap: 10px;
      flex-wrap: wrap; margin-bottom: 20px;
    }
    .cat-badge { font-size: 11px; font-weight: 600; padding: 2px 9px; border-radius: 20px; }
    .meta-sep  { color: rgba(255,255,255,0.12); }
    .meta-item { font-size: 12.5px; color: var(--text-dim); }

    .article-title {
      font-size: clamp(26px, 4vw, 38px);
      font-weight: 700; letter-spacing: -1.5px; line-height: 1.12;
      color: var(--text); margin-bottom: 16px;
    }
    .article-desc {
      font-size: 16px; color: var(--text-muted);
      line-height: 1.65; margin-bottom: 20px; letter-spacing: -0.1px;
    }
    .article-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag {
      font-size: 11px; font-weight: 500; color: var(--text-dim);
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
      padding: 2px 8px; border-radius: 6px;
      font-family: var(--mono);
    }

    .article-divider { height: 1px; background: rgba(255,255,255,0.06); margin: 40px 0; }

    /* ── Prose ── */
    .prose { color: var(--text-muted); font-size: 16px; }

    .prose h1, .prose h2, .prose h3, .prose h4 { color: var(--text); font-weight: 700; line-height: 1.3; }

    .prose h2 {
      font-size: 22px; letter-spacing: -0.5px;
      margin: 48px 0 18px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .prose h3 {
      font-size: 17px; letter-spacing: -0.3px; margin: 36px 0 12px;
    }
    .prose h3::before {
      content: '### ';
      font-family: var(--mono); font-size: 13px;
      color: var(--text-dim); font-weight: 400;
    }
    .prose h4 {
      font-size: 14px; font-weight: 600;
      letter-spacing: 0.3px; text-transform: uppercase;
      color: var(--text-dim); margin: 28px 0 10px;
    }

    .prose p { margin-bottom: 18px; line-height: 1.8; }
    .prose strong { color: var(--text); font-weight: 600; }
    .prose em { font-style: italic; }

    .prose a {
      color: var(--accent);
      text-decoration: underline; text-underline-offset: 3px;
      text-decoration-color: rgba(41,151,255,0.35);
      transition: text-decoration-color .15s;
    }
    .prose a:hover { text-decoration-color: var(--accent); }

    .prose :not(pre) > code {
      font-family: var(--mono); font-size: 13px;
      background: rgba(175,184,193,0.12); color: #e6edf3;
      padding: 2px 6px; border-radius: 5px;
    }
    .prose pre {
      background: var(--code-bg); border: 1px solid var(--code-border);
      border-radius: var(--radius-sm); padding: 18px 20px;
      overflow-x: auto; margin: 22px 0;
      font-family: var(--mono); font-size: 13px; line-height: 1.7;
      color: var(--code-text);
    }
    .prose pre code { background: none; border: none; padding: 0; color: inherit; font-size: inherit; }

    .prose blockquote {
      border-left: 3px solid var(--accent);
      background: rgba(41,151,255,0.05);
      padding: 14px 18px;
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
      margin: 22px 0; color: var(--text-muted);
    }
    .prose blockquote p { margin: 0; }

    .prose ul, .prose ol { padding-left: 22px; margin: 16px 0; }
    .prose ul { list-style: disc; }
    .prose ul li::marker { color: var(--accent); }
    .prose ol { list-style: decimal; }
    .prose ol li::marker { color: var(--accent); font-weight: 600; }
    .prose li { margin-bottom: 7px; line-height: 1.75; }
    .prose li p { margin: 0; }

    /* Wrap tables for horizontal scroll on mobile */
    .prose table {
      width: 100%; border-collapse: collapse;
      font-size: 14px; margin: 0;
      border: 1px solid var(--code-border);
      border-radius: var(--radius-sm);
    }
    .prose :where(table) { display: block; overflow-x: auto; margin: 22px 0; }
    .prose thead th {
      background: rgba(255,255,255,0.04); color: var(--text-muted);
      font-size: 12px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.4px;
      padding: 10px 16px; text-align: left;
      border-bottom: 1px solid var(--code-border);
    }
    .prose tbody td {
      padding: 10px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      color: var(--text-muted); vertical-align: top;
    }
    .prose tbody tr:last-child td { border-bottom: none; }
    .prose tbody tr:nth-child(even) td { background: rgba(255,255,255,0.015); }
    .prose tbody tr:hover td { background: rgba(255,255,255,0.03); }
    .prose tbody td:first-child { color: var(--text); font-weight: 500; }

    .prose hr { border: none; height: 1px; background: rgba(255,255,255,0.06); margin: 40px 0; }
    .prose img { max-width: 100%; border-radius: var(--radius-sm); margin: 22px 0; }

    /* ── Footer ── */
    .footer {
      border-top: 1px solid rgba(255,255,255,0.05);
      padding: 36px 10%; text-align: center;
      color: var(--text-dim); font-size: 13px; line-height: 1.8;
      max-width: 780px;
    }
    .footer a { color: #636366; transition: color .15s; }
    .footer a:hover { color: var(--text-muted); }

    @media (max-width: 680px) {
      .nav { padding: 0 20px; }
      .footer { padding: 28px 6%; max-width: none; }
    }
  </style>
</head>
<body>

  <div id="progress-bar" data-pagefind-ignore="all"></div>

  <nav class="nav" data-pagefind-ignore="all">
    <a href={`${base}/`} class="nav-logo">
      <span class="nav-logo-icon">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M2 10L6 2L10 10" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M3.5 7.5H8.5" stroke="white" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </span>
      Vibe Reading
    </a>
    <div class="nav-right">
      <button class="search-btn" onclick="window.openSearch?.()" aria-label="搜索">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="search-btn-hint">⌘K</span>
      </button>
      <button class="mob-menu-btn" onclick="window.openMobileSidebar?.()" aria-label="打开菜单">
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
          <path d="M1 1h16M1 7h16M1 13h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </button>
      <button class="nav-pill" onclick="history.back()">← 返回</button>
      <a href="https://github.com/Dragonliu2018/vibe-reading" target="_blank" rel="noopener" class="nav-pill">GitHub</a>
    </div>
  </nav>

  <div class="layout">

    <!-- Persistent sidebar — highlights current article -->
    <Sidebar currentSlug={currentSlug} />

    <!-- Article scroll panel -->
    <div class="main-scroll">
      <div class="article-with-toc">

        <!-- Article content -->
        <div class="article-col">

          <header class="article-header">
            <div class="article-meta">
              {color && category && (
                <span class="cat-badge" style={`color:${color.text};background:${color.bg};border:1px solid ${color.border};`}>
                  {CATEGORY_LABEL[category]}
                </span>
              )}
              {date        && <><span class="meta-sep">·</span><span class="meta-item">{date}</span></>}
              {readingTime && <><span class="meta-sep">·</span><span class="meta-item">{readingTime}</span></>}
              {aiModel     && <><span class="meta-sep">·</span><span class="meta-item">{aiModel}</span></>}
            </div>

            <h1 class="article-title" data-pagefind-meta="title">{title}</h1>
            {description && <p class="article-desc">{description}</p>}

            {tags.length > 0 && (
              <div class="article-tags">
                {tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            )}
          </header>

          <div class="article-divider"></div>

          <article class="prose">
            <slot />
          </article>

        </div>

        <!-- Right TOC (h2 + h3) -->
        {tocHeadings.length > 0 && (
          <aside class="toc-panel" data-pagefind-ignore="all">
            <p class="toc-heading">目录</p>
            <ul class="toc-list">
              {tocHeadings.map(h => (
                <li>
                  <a
                    href={`#${h.slug}`}
                    class:list={['toc-link', `depth-${h.depth}`]}
                    title={h.text}
                  >{h.text}</a>
                </li>
              ))}
            </ul>
          </aside>
        )}

      </div>

      <footer class="footer" data-pagefind-ignore="all">
        Vibe Reading · AI-drafted · Human-reviewed &nbsp;·&nbsp;
        <a href={`${base}/`}>← 返回首页</a> &nbsp;·&nbsp;
        <a href="https://github.com/Dragonliu2018/vibe-reading" target="_blank" rel="noopener">GitHub</a>
      </footer>
    </div>

  </div>

  <script>
    const bar    = document.getElementById('progress-bar')!;
    const scroll = document.querySelector<HTMLElement>('.main-scroll');

    // Reading progress bar
    if (scroll) {
      scroll.addEventListener('scroll', () => {
        const pct = scroll.scrollTop / (scroll.scrollHeight - scroll.clientHeight);
        bar.style.width = (pct * 100) + '%';
      });
    }

    // TOC active highlight via IntersectionObserver
    const tocLinks  = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    const headingEls = document.querySelectorAll<HTMLElement>('article h2[id], article h3[id]');

    if (tocLinks.length && headingEls.length && scroll) {
      const setActive = (id: string) => {
        tocLinks.forEach(a => {
          a.classList.toggle('active', a.getAttribute('href') === `#${id}`);
        });
      };

      const obs = new IntersectionObserver(entries => {
        for (const e of entries) {
          if (e.isIntersecting) {
            setActive(e.target.getAttribute('id') ?? '');
          }
        }
      }, {
        root: scroll,
        rootMargin: '-52px 0px -55% 0px',
      });

      headingEls.forEach(h => obs.observe(h));
    }
  </script>

  <SearchModal />

</body>
</html>
