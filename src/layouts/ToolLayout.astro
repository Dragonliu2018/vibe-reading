---
import Sidebar from '../components/Sidebar.astro';
import SearchModal from '../components/SearchModal.astro';
import NavBar from '../components/NavBar.astro';

export interface Props {
  title:        string;
  description?: string;
  toolHref:     string;   // 当前工具路径，用于侧边栏高亮，如 '/tools/diff'
}

const { title, description, toolHref } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · Vibe Reading</title>
  {description && <meta name="description" content={description} />}
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #000000;
      --surface:     #141416;
      --border:      rgba(255,255,255,0.08);
      --border-lite: rgba(255,255,255,0.05);
      --text:        #f5f5f7;
      --text-muted:  #86868b;
      --text-dim:    #48484a;
      --accent:      #2997ff;
      --accent-light:rgba(41,151,255,0.12);
      --radius:      12px;
      --radius-sm:   8px;
      --font: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      --mono: ui-monospace, 'SF Mono', SFMono-Regular, 'JetBrains Mono', Menlo, Consolas, monospace;
    }

    html, body { height: 100%; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 15px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      display: flex; flex-direction: column;
      overflow: hidden;
    }

    @media (max-width: 959px) {
      html, body { height: auto; overflow: visible; }
      body { display: block; }
    }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
    a { text-decoration: none; color: inherit; }

    /* ── Layout ── */
    .layout {
      flex: 1; overflow: hidden;
      display: flex; align-items: stretch;
    }
    @media (max-width: 959px) {
      .layout { flex: none; overflow: visible; display: block; }
    }

    /* ── Tool scroll panel ── */
    .tool-scroll {
      flex: 1; min-width: 0;
      height: 100%; overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.1) transparent;
    }
    .tool-scroll::-webkit-scrollbar { width: 4px; }
    .tool-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
    @media (max-width: 959px) {
      .tool-scroll { flex: none; height: auto; overflow: visible; }
    }

    /* ── Tool content area ── */
    .tool-body {
      max-width: 860px;
      padding: 40px 52px 80px 52px;
    }
    @media (max-width: 959px) { .tool-body { padding: 28px 6% 60px; max-width: none; } }

    .tool-title {
      font-size: 26px; font-weight: 700; letter-spacing: -0.8px;
      color: var(--text); margin-bottom: 6px;
    }
    .tool-desc {
      font-size: 14px; color: var(--text-muted); margin-bottom: 32px;
      line-height: 1.6;
    }

    /* ── Tool UI primitives (共用) ── */
    .tool-row {
      display: grid; gap: 16px;
      grid-template-columns: 1fr 1fr;
    }
    @media (max-width: 680px) { .tool-row { grid-template-columns: 1fr; } }

    .tool-label {
      font-size: 11.5px; font-weight: 600; letter-spacing: 0.4px;
      text-transform: uppercase; color: var(--text-dim);
      margin-bottom: 8px;
    }

    textarea, input[type="text"], input[type="number"] {
      width: 100%; background: var(--surface);
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      color: var(--text); font-family: var(--mono); font-size: 13px;
      padding: 12px 14px; resize: vertical; outline: none;
      transition: border-color .15s;
    }
    textarea:focus, input:focus { border-color: var(--accent); }
    textarea { min-height: 160px; line-height: 1.6; }

    .tool-btn {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 13px; font-weight: 500; font-family: var(--font);
      padding: 8px 18px; border-radius: 20px; border: none; cursor: pointer;
      transition: opacity .15s, transform .1s;
    }
    .tool-btn:active { transform: scale(0.97); }
    .tool-btn-primary {
      background: var(--accent); color: #fff;
    }
    .tool-btn-secondary {
      background: rgba(255,255,255,0.08); color: var(--text-muted);
      border: 1px solid var(--border);
    }
    .tool-btn-secondary:hover { color: var(--text); background: rgba(255,255,255,0.12); }

    .tool-actions { display: flex; gap: 8px; margin: 14px 0; flex-wrap: wrap; }

    .tool-divider {
      height: 1px; background: var(--border-lite);
      margin: 28px 0;
    }

    .tool-footer {
      border-top: 1px solid var(--border-lite);
      padding: 24px 52px; text-align: center;
      color: var(--text-dim); font-size: 13px;
    }
    .tool-footer a { color: #636366; transition: color .15s; }
    .tool-footer a:hover { color: var(--text-muted); }
    @media (max-width: 959px) { .tool-footer { padding: 20px 6%; } }
  </style>
</head>
<body>

  <NavBar mode="tools" />

  <div class="layout">
    <Sidebar mode="tools" currentHref={toolHref} />

    <div class="tool-scroll">
      <div class="tool-body">
        <h1 class="tool-title">{title}</h1>
        {description && <p class="tool-desc">{description}</p>}
        <slot />
      </div>
      <footer class="tool-footer">
        Vibe Reading · <a href={`${base}/`}>← 返回首页</a>
      </footer>
    </div>
  </div>

  <SearchModal />

</body>
</html>
