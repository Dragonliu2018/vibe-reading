---
import { articles, CATEGORY_LABEL, CATEGORY_COLOR, type Category } from '../data/articles';
import { quotes } from '../data/quotes';
import Sidebar from '../components/Sidebar.astro';
import SearchModal from '../components/SearchModal.astro';

// 构建时嵌入，无运行时请求
const quotesJson = JSON.stringify(quotes);

const sorted = [...articles].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const totalByCategory = sorted.reduce<Record<string, number>>((acc, a) => {
  acc[a.category] = (acc[a.category] ?? 0) + 1;
  return acc;
}, {});
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vibe Reading · 技术文档解读博客</title>
  <meta name="description" content="AI-drafted, human-reviewed technical reading blog — code walkthroughs and paper breakdowns." />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:            #000000;
      --bg-secondary:  #1c1c1e;   /* Apple 系统深灰，卡片实色背景 */
      --card-bg:       #141416;   /* 比纯黑略亮，有层次感 */
      --card-border:   rgba(255,255,255,0.10);
      --card-shadow:   0 1px 3px rgba(0,0,0,0.25), 0 4px 16px rgba(0,0,0,0.35);
      --card-shadow-h: 0 4px 8px rgba(0,0,0,0.30), 0 12px 32px rgba(0,0,0,0.45);
      --text:          #f5f5f7;
      --text-muted:    #86868b;
      --text-dim:      #48484a;
      --accent:        #2997ff;
      --accent-light:  rgba(41,151,255,0.12);
      --radius:        18px;
      --radius-sm:     10px;
      --font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      --mono: ui-monospace, 'SF Mono', SFMono-Regular, 'JetBrains Mono', Menlo, monospace;
    }

    html, body { height: 100%; }

    body {
      background: var(--bg);
      background-image: radial-gradient(ellipse 80% 45% at 50% -5%, rgba(41,151,255,0.12) 0%, transparent 70%);
      color: var(--text);
      font-family: var(--font);
      font-size: 16px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    @media (max-width: 959px) {
      html, body { height: auto; overflow: visible; }
      body { display: block; }
    }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
    a { text-decoration: none; color: inherit; }

    /* ── Nav ── */
    .nav {
      flex-shrink: 0;
      position: sticky; top: 0; z-index: 100;
      background: rgba(0,0,0,0.75);
      backdrop-filter: saturate(180%) blur(24px);
      -webkit-backdrop-filter: saturate(180%) blur(24px);
      border-bottom: 1px solid rgba(255,255,255,0.10);
      height: 52px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 48px;
    }
    .nav-logo {
      display: flex; align-items: center; gap: 9px;
      font-size: 15px; font-weight: 600; letter-spacing: -0.3px;
    }
    .nav-logo-icon {
      width: 22px; height: 22px; border-radius: 7px;
      background: linear-gradient(135deg, #2997ff 0%, #30d158 100%);
      display: flex; align-items: center; justify-content: center;
    }
    .nav-pill {
      font-size: 13px; color: var(--text-muted);
      padding: 5px 14px; border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      transition: color .15s, border-color .15s, background .15s;
      display: flex; align-items: center; gap: 6px;
    }
    .nav-pill:hover { color: var(--text); border-color: rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); }

    /* Search button */
    .search-btn {
      display: flex; align-items: center; gap: 6px;
      font-size: 13px; color: var(--text-muted);
      padding: 5px 12px; border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      cursor: pointer; white-space: nowrap;
      transition: color .15s, border-color .15s, background .15s;
      font-family: var(--font);
    }
    .search-btn:hover { color: var(--text); border-color: rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); }
    .search-btn-hint { font-size: 11px; color: var(--text-dim); }
    @media (max-width: 680px) { .search-btn-hint { display: none; } }

    /* Hamburger — mobile only */
    .mob-menu-btn {
      display: none;
      align-items: center; justify-content: center;
      width: 40px; height: 40px; border-radius: 10px;
      background: none; border: none; cursor: pointer;
      color: var(--text-muted); transition: color .15s, background .15s;
      flex-shrink: 0;
    }
    .mob-menu-btn:hover { color: var(--text); background: rgba(255,255,255,0.06); }
    @media (max-width: 959px) { .mob-menu-btn { display: flex; } }

    /* ── Two-column layout ── */
    .layout {
      flex: 1;
      overflow: hidden;
      display: flex;
      align-items: stretch;
    }
    @media (max-width: 959px) {
      .layout { flex: none; overflow: visible; display: block; }
    }

    /* ── Right scroll panel ── */
    .main-scroll {
      flex: 1; min-width: 0;
      height: 100%; overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.1) transparent;
    }
    .main-scroll::-webkit-scrollbar { width: 4px; }
    .main-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
    @media (max-width: 959px) {
      .main-scroll { flex: none; height: auto; overflow: visible; }
    }

    /* ── Hero ── */
    .hero {
      padding: 44px 10% 48px;
      text-align: center;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 13px; font-weight: 600; letter-spacing: 0.5px;
      color: var(--accent); text-transform: uppercase;
      background: var(--accent-light);
      border: 1px solid rgba(41,151,255,0.25);
      padding: 5px 14px; border-radius: 100px;   /* Paperclip 风格 pill badge */
      margin-bottom: 24px;
    }
    .hero h1 {
      font-size: clamp(36px, 5vw, 52px);
      font-weight: 700; letter-spacing: -2px; line-height: 1.06;
      /* 更苹果：primary → secondary 二段渐变，不做三段 */
      background: linear-gradient(180deg, #f5f5f7 0%, #86868b 120%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      margin-bottom: 18px;
    }
    /* ── 哲理语句区 ── */
    .quote-wrap {
      position: relative;
      height: 92px;              /* 固定高度：内容变化不传导到外部，消灭抖动 */
      max-width: 480px;
      margin: 20px auto 18px;
      overflow: hidden;
    }
    @media (max-width: 680px) {
      .quote-wrap { height: 118px; }     /* 窄屏长句可能多折一行 */
      .quote-text { font-size: 13.5px; } /* 略缩字号，每行多容纳几个字符 */
      .hero h1    { letter-spacing: -1.5px; } /* 小尺寸下 -2px 偏紧 */
    }
    .quote-inner {
      position: absolute;        /* 脱离文档流，高度变化不影响容器 */
      inset: 0;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      transition: opacity .5s cubic-bezier(0.4,0,0.2,1),
                  transform .5s cubic-bezier(0.4,0,0.2,1);
    }
    .quote-inner.out {
      opacity: 0;
      transform: translateY(-7px);
    }
    .quote-inner.in {
      opacity: 0;
      transform: translateY(7px);
    }
    .quote-text {
      font-size: 14.5px; font-style: italic; font-weight: 400;
      color: rgba(245,245,247,0.62);
      line-height: 1.65; letter-spacing: -0.05px;
    }
    .quote-author {
      font-size: 11.5px; margin-top: 7px;
      color: rgba(245,245,247,0.28); letter-spacing: 0.1px;
    }


    /* ── Main content col ── */
    .main-col { min-width: 0; padding: 0 10% 120px 52px; }
    @media (max-width: 959px) { .main-col { padding: 0 6% 80px; } }

    /* Filter tabs */
    .filter-tabs {
      display: flex;
      flex-wrap: wrap;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: var(--radius-sm);
      padding: 3px; gap: 2px;
      margin-bottom: 32px;
      max-width: 100%;
    }
    .filter-tab {
      font-size: 13.5px; font-weight: 500;
      padding: 6px 16px; border-radius: 8px;
      color: var(--text-muted);
      cursor: pointer; border: none; background: none;
      transition: color .15s, background .15s;
      display: flex; align-items: center; gap: 7px;
    }
    .filter-tab:hover { color: var(--text); }
    .filter-tab.active { background: rgba(255,255,255,0.09); color: var(--text); }
    .filter-count {
      font-size: 11px; font-weight: 600; color: var(--text-dim);
      background: rgba(255,255,255,0.06); padding: 1px 7px; border-radius: 20px;
    }
    .filter-tab.active .filter-count { color: #636366; }

    /* Section label */
    .section-label {
      display: flex; align-items: center; gap: 14px; margin-bottom: 18px;
    }
    .section-label-text {
      font-size: 11px; font-weight: 600; letter-spacing: 0.9px;
      text-transform: uppercase; color: var(--text-dim); white-space: nowrap;
    }
    .section-label-line { flex: 1; height: 1px; background: rgba(255,255,255,0.10); }

    /* Article list */
    .articles { display: flex; flex-direction: column; }

    .article-card {
      display: block;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-bottom: none;
      padding: 22px 26px;
      box-shadow: var(--card-shadow);      /* ← 双层阴影，Paperclip 标志 */
      transition: background .22s, transform .25s ease, box-shadow .25s ease;
      position: relative;
    }
    .article-card:last-of-type { border-bottom: 1px solid var(--card-border); }
    .article-card:first-of-type { border-radius: var(--radius) var(--radius) 0 0; }
    .article-card:last-of-type  { border-radius: 0 0 var(--radius) var(--radius); }
    .article-card:only-of-type  { border-radius: var(--radius); border-bottom: 1px solid var(--card-border); }
    .article-card:hover {
      background: #1a1a1d;
      transform: translateY(-2px);         /* ← Paperclip hover 上浮 */
      box-shadow: var(--card-shadow-h);
      z-index: 1;
    }
    .article-card:hover .card-title { color: var(--accent); }

    .card-inner { display: grid; grid-template-columns: 1fr auto; gap: 20px; align-items: start; }
    .card-meta { display: flex; align-items: center; gap: 9px; margin-bottom: 8px; flex-wrap: wrap; }
    .cat-badge { font-size: 10.5px; font-weight: 600; padding: 2px 8px; border-radius: 20px; letter-spacing: 0.2px; }
    .card-title { font-size: 16.5px; font-weight: 600; color: var(--text); letter-spacing: -0.4px; line-height: 1.35; margin-bottom: 7px; transition: color .15s; }
    .card-desc { font-size: 13.5px; color: var(--text-muted); line-height: 1.65; margin-bottom: 13px; }
    .card-tags { display: flex; flex-wrap: wrap; gap: 5px; }
    .tag {
      font-size: 11px; font-weight: 500; color: var(--text-dim);
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);
      padding: 2px 8px; border-radius: 6px; font-family: var(--mono);
    }
    .card-aside { text-align: right; flex-shrink: 0; padding-top: 2px; }
    .card-date { font-size: 12px; color: var(--text-dim); font-variant-numeric: tabular-nums; display: block; margin-bottom: 3px; white-space: nowrap; }
    .card-reading { font-size: 11.5px; color: var(--text-dim); white-space: nowrap; }

    .empty { display: none; text-align: center; padding: 80px 0; color: var(--text-dim); font-size: 15px; }

    /* ── Footer ── */
    .footer {
      border-top: 1px solid rgba(255,255,255,0.05);
      padding: 36px 10%; text-align: center;
      color: var(--text-dim); font-size: 13px; line-height: 1.8;
    }
    .footer a { color: #636366; transition: color .15s; }
    .footer a:hover { color: var(--text-muted); }

    /* ── Fade-up 入场动画（Paperclip 风格）── */
    @media (prefers-reduced-motion: no-preference) {
      .fade-up {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity .5s ease, transform .5s ease;
      }
      .fade-up.visible {
        opacity: 1;
        transform: translateY(0);
      }
      /* Stagger：子元素依次延迟出现 */
      .stagger > .article-card:nth-child(1) { transition-delay: 0ms; }
      .stagger > .article-card:nth-child(2) { transition-delay: 60ms; }
      .stagger > .article-card:nth-child(3) { transition-delay: 120ms; }
      .stagger > .article-card:nth-child(4) { transition-delay: 180ms; }
      .stagger > .article-card:nth-child(5) { transition-delay: 240ms; }
      .stagger > .article-card:nth-child(6) { transition-delay: 300ms; }
      .stagger > .article-card:nth-child(7) { transition-delay: 360ms; }
      .stagger > .article-card:nth-child(8) { transition-delay: 420ms; }
    }

    /* ── Responsive ── */
    @media (max-width: 680px) {
      .nav { padding: 0 20px; }
      .hero { padding: 28px 6% 28px; }
      .card-inner { grid-template-columns: 1fr; gap: 10px; }
      .card-aside { text-align: left; }
      .footer { padding: 28px 6%; }
    }
  </style>
</head>
<body>

  <nav class="nav" data-pagefind-ignore="all">
    <a href={base} class="nav-logo">
      <span class="nav-logo-icon">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M2 10L6 2L10 10" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M3.5 7.5H8.5" stroke="white" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </span>
      Vibe Reading
    </a>
    <div style="display:flex;align-items:center;gap:6px;">
      <button class="search-btn" onclick="window.openSearch?.()" aria-label="搜索">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="search-btn-hint">⌘K</span>
      </button>
      <button class="mob-menu-btn" onclick="window.openMobileSidebar?.()" aria-label="打开菜单">
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
          <path d="M1 1h16M1 7h16M1 13h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </button>
      <a href="https://github.com/Dragonliu2018/vibe-reading" target="_blank" rel="noopener" class="nav-pill">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        GitHub
      </a>
    </div>
  </nav>

  <div class="layout">
    <Sidebar />

    <div class="main-scroll">

      <section class="hero">
        <span class="hero-eyebrow fade-up">AI-drafted · Human-reviewed</span>
        <h1 class="fade-up" style="transition-delay:80ms">Vibe Reading</h1>

        <!-- 哲理语句：构建时嵌入数据，运行时轮播 -->
        <div class="quote-wrap fade-up" style="transition-delay:160ms">
          <div class="quote-inner" id="quote-inner">
            <p class="quote-text" id="quote-text"></p>
            <p class="quote-author" id="quote-author"></p>
          </div>
        </div>

      </section>

      <div class="main-col">
        <div class="filter-tabs">
          <button class="filter-tab active" data-filter="all">
            全部 <span class="filter-count">{sorted.length}</span>
          </button>
          {(['code', 'paper', 'system'] as Category[]).map(cat => {
            const count = totalByCategory[cat] ?? 0;
            if (count === 0) return null;
            return (
              <button class="filter-tab" data-filter={cat}>
                {CATEGORY_LABEL[cat]} <span class="filter-count">{count}</span>
              </button>
            );
          })}
        </div>

        <div class="section-label">
          <span class="section-label-text" id="section-title">所有文章</span>
          <div class="section-label-line"></div>
        </div>

        <main class="articles stagger" id="article-list">
          {sorted.map((article) => {
            const color = CATEGORY_COLOR[article.category];
            return (
              <a class="article-card fade-up" href={`${base}/articles/${article.slug}`} data-category={article.category}>
                <div class="card-inner">
                  <div>
                    <div class="card-meta">
                      <span class="cat-badge" style={`color:${color.text};background:${color.bg};border:1px solid ${color.border};`}>
                        {CATEGORY_LABEL[article.category]}
                      </span>
                    </div>
                    <div class="card-title">{article.title}</div>
                    <div class="card-desc">{article.description}</div>
                    <div class="card-tags">
                      {article.tags.map(tag => <span class="tag">{tag}</span>)}
                    </div>
                  </div>
                  <div class="card-aside">
                    <span class="card-date">{article.date}</span>
                    {article.readingTime && <span class="card-reading">{article.readingTime}</span>}
                  </div>
                </div>
              </a>
            );
          })}
          <div class="empty" id="empty-state">暂无该分类的文章</div>
        </main>
      </div>

      <footer class="footer">
        Vibe Reading · AI-drafted · Human-reviewed &nbsp;·&nbsp;
        <a href="https://github.com/Dragonliu2018/vibe-reading" target="_blank" rel="noopener">GitHub</a>
        &nbsp;·&nbsp; Astro
      </footer>

    </div>
  </div>

  <!-- 哲理语句轮播：数据在构建时嵌入，无运行时请求 -->
  <script define:vars={{ quotes }}>
    const inner  = document.getElementById('quote-inner');
    const textEl = document.getElementById('quote-text');
    const authEl = document.getElementById('quote-author');

    if (inner && textEl && authEl && quotes.length) {
      const SHOW_MS = 12000;   // 每句展示 12 秒
      const FADE_MS = 500;     // 淡入淡出 0.5 秒

      // 第一条固定展示博客主旨，之后随机轮播其余语句
      let idx = 0;

      function setQuote(q) {
        textEl.textContent = '“' + q.text + '”';
        authEl.textContent = q.author ? '— ' + q.author : '';
      }

      function cycle() {
        // 淡出：向上飘走
        inner.classList.add('out');

        setTimeout(() => {
          idx = (idx + 1) % quotes.length;
          setQuote(quotes[idx]);

          // 重置到下方（无动画）
          inner.classList.remove('out');
          inner.classList.add('in');

          // 双帧确保浏览器渲染 in 状态后再触发淡入
          requestAnimationFrame(() => requestAnimationFrame(() => {
            inner.classList.remove('in');   // 触发 transition → 正常显示
          }));

          setTimeout(cycle, SHOW_MS);
        }, FADE_MS);
      }

      // 首屏立即显示第一句
      setQuote(quotes[idx]);
      setTimeout(cycle, SHOW_MS);
    }
  </script>

  <script>
    const tabs  = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
    const cards = document.querySelectorAll<HTMLElement>('.article-card');
    const empty = document.getElementById('empty-state')!;
    const sectionTitle = document.getElementById('section-title')!;
    const LABELS: Record<string, string> = {
      all: '所有文章', code: '代码解读', paper: '论文解读', system: '系统设计',
    };
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const f = tab.dataset.filter!;
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        sectionTitle.textContent = LABELS[f] ?? '所有文章';
        let n = 0;
        cards.forEach(c => {
          const show = f === 'all' || c.dataset.category === f;
          c.style.display = show ? '' : 'none';
          if (show) n++;
        });
        empty.style.display = n === 0 ? 'block' : 'none';
      });
    });

    // ── Fade-up 入场动画（Paperclip 风格）──────────────────────────
    const fadeEls = document.querySelectorAll<HTMLElement>('.fade-up');
    const scroller = document.querySelector<HTMLElement>('.main-scroll') ?? window;
    const fadeObs = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.08 }
    );
    fadeEls.forEach(el => fadeObs.observe(el));
  </script>

  <SearchModal />

</body>
</html>
