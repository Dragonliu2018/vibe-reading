---
import ToolLayout from '../../layouts/ToolLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tools = [
  { label: 'Text Diff',   desc: '对比两段文本，高亮差异',   href: `${base}/tools/diff`   },
  { label: 'Base64',      desc: '文本与 Base64 互相转码',   href: `${base}/tools/base64` },
  { label: 'URL 编解码',  desc: '对 URL 进行编码或解码',    href: `${base}/tools/url`    },
  { label: '存储单位换算', desc: 'B / KB / MB / GB / TB 互换', href: `${base}/tools/units`  },
];
---

<ToolLayout title="工具箱" description="常用开发者工具" toolHref="/tools">
  <style>
    .tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 14px;
    }
    .tool-card {
      display: block;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 20px;
      text-decoration: none;
      transition: background .15s, border-color .15s, transform .15s;
    }
    .tool-card:hover {
      background: rgba(255,255,255,0.07);
      border-color: rgba(255,255,255,0.15);
      transform: translateY(-2px);
    }
    .tool-card-name {
      font-size: 15px; font-weight: 600;
      color: #f5f5f7; letter-spacing: -0.2px;
      margin-bottom: 6px;
    }
    .tool-card-desc {
      font-size: 12.5px; color: #636366; line-height: 1.5;
    }
  </style>

  <div class="tools-grid">
    {tools.map(t => (
      <a class="tool-card" href={t.href}>
        <div class="tool-card-name">{t.label}</div>
        <div class="tool-card-desc">{t.desc}</div>
      </a>
    ))}
  </div>
</ToolLayout>
